<rxui:ReactiveUserControl 
	        x:TypeArguments="viewModels:DialogViewModel" 
	        xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             xmlns:rxui="http://reactiveui.net"
	        x:DataType="viewModels:DialogViewModel"
			 x:CompileBindings="True"
			 xmlns:controls="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
				xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
				xmlns:viewModels="clr-namespace:CTUScheduler.Presentation.Scheduling.ViewModels"
				x:Class="CTUScheduler.Presentation.Scheduling.Views.DialogView">
	
		<Design.DataContext>
			<viewModels:DialogViewModel/>
		</Design.DataContext>



	<controls:Card x:Name="CardBorder"
			 MinWidth ="850" MinHeight="500"
			 Padding="0"
			 >
			<Grid RowDefinitions="auto *">
				<Button
					Grid.Row="0"
					x:Name="btnClose"
					Content="{materialIcons:MaterialIconExt Kind=WindowClose,Size=20}"
					CornerRadius="5"
					HorizontalAlignment="Right"
					Command="{Binding CloseDialogCommand}"
					Padding="3"/>

				<rxui:RoutedViewHost
					Router="{Binding Router}"
					Grid.Row="1"
				/>
			</Grid>
		</controls:Card>


</rxui:ReactiveUserControl>
