<rxui:ReactiveUserControl
			x:TypeArguments="vm:SettingViewModel"
			xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
			 xmlns:rxui="http://reactiveui.net"
			 xmlns:vm="clr-namespace:CTUScheduler.Presentation.Setting.ViewModels"
			 x:DataType="vm:SettingViewModel"
			 x:CompileBindings="True"
             x:Class="CTUScheduler.Presentation.Setting.Views.SettingView">

	<Design.DataContext>
		<vm:SettingViewModel/>
	</Design.DataContext>

	<Grid>
		<TextBlock Text="Setting view" FontSize="100"/>
	</Grid>
</rxui:ReactiveUserControl>
