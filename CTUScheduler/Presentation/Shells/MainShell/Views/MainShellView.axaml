<rxui:ReactiveUserControl
    x:TypeArguments="vm:MainShellViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
    xmlns:rxui="http://reactiveui.net"
    x:DataType="vm:MainShellViewModel"
    x:CompileBindings="True"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:controls="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
    xmlns:ripple="clr-namespace:Material.Ripple;assembly=Material.Ripple"
    xmlns:themes="clr-namespace:Material.Styles.Themes;assembly=Material.Styles"
    xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
    xmlns:positioners="clr-namespace:DialogHostAvalonia.Positioners;assembly=DialogHost.Avalonia"
    xmlns:vm="clr-namespace:CTUScheduler.Presentation.Shells.MainShell.ViewModels"
    xmlns:models="clr-namespace:CTUScheduler.Presentation.Shells.MainShell.Models"
    xmlns:views="clr-namespace:CTUScheduler.Presentation.Shells.MainShell.Views"
    xmlns:timetableViewModel="clr-namespace:CTUScheduler.Presentation.Features.Timetable.ViewModels"
    xmlns:timetableView="clr-namespace:CTUScheduler.Presentation.Features.Timetable.Views"
    xmlns:viewModels="clr-namespace:CTUScheduler.Presentation.Features.Scheduling.Shells.ViewModels"
    xmlns:views2="clr-namespace:CTUScheduler.Presentation.Features.Scheduling.Shells.Views"
    x:Class="CTUScheduler.Presentation.Shells.MainShell.Views.MainShellView">

    <rxui:ReactiveUserControl.Styles>
        <themes:CustomMaterialTheme PrimaryColor="Blue" SecondaryColor="#1f5ca9" />
    </rxui:ReactiveUserControl.Styles>

    <Design.DataContext>
        <vm:MainShellViewModel />
    </Design.DataContext>
    <!-- // Main Dialog // -->
    <Grid>
        <dialogHostAvalonia:DialogHost Identifier="MainLayout" CloseOnClickAway="False">
            <dialogHostAvalonia:DialogHost.DataTemplates>
                <DataTemplate x:DataType="{x:Type vm:LogoutDialogViewModel}">
                    <views:LogoutDialogView />
                </DataTemplate>
                <DataTemplate x:DataType="{x:Type viewModels:DialogShellViewModel}">
                    <views2:DialogShellView />
                </DataTemplate>
            </dialogHostAvalonia:DialogHost.DataTemplates>
            <!-- // Main Content // -->
            <controls:NavigationDrawer
                x:Name="LeftDrawer"
                LeftDrawerOpened="{Binding ElementName=ExpandToggleButton,Path=IsChecked,Mode=TwoWay}"
                LeftDrawerExpandThresholdWidth="999"
                LeftDrawerWidth="220">
                <controls:NavigationDrawer.LeftDrawerContent>
                    <DockPanel Background="#ECECEC">
                        <!--// CTU Title //-->
                        <Border Padding="15" Height="70" DockPanel.Dock="Top">
                            <Grid ColumnDefinitions="auto *">
                                <Image Grid.Column="0"
                                       Height="50"
                                       Width="50"
                                       Source="/Assets/Images/CTU Logo/CTU_logo_50x50.png" />
                                <TextBlock Grid.Column="1" Text="Cần Thơ University"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontFamily="{StaticResource Ctu-Title-Font}" />
                            </Grid>
                        </Border>

                        <!--// Student Info //-->
                        <StackPanel DockPanel.Dock="Top">
                            <Border Padding="15">
                                <Border MinHeight="60" CornerRadius="10" Background="White">
                                    <Grid ColumnDefinitions="50 *">
                                        <materialIcons:MaterialIcon Grid.Column="0"
                                                                    Kind="AccountSchool"
                                                                    Height="40"
                                                                    Width="40"
                                                                    Foreground="{StaticResource PrimaryColor}" />
                                        <Grid Grid.Column="1" RowDefinitions="* *">
                                            <Grid.Styles>
                                                <Style Selector="SelectableTextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                    <Setter Property="TextWrapping" Value="WrapWithOverflow" />
                                                    <Setter Property="SelectionForegroundBrush" Value="White" />
                                                </Style>
                                            </Grid.Styles>
                                            <SelectableTextBlock x:Name="txtUserName"
                                                                 Grid.Row="0"
                                                                 Text="{Binding UserName, Mode=OneWay}"
                                                                 VerticalAlignment="Bottom"
                                                                 FontWeight="Bold"
                                                                 FontSize="15" />
                                            <SelectableTextBlock x:Name="txtMSSV"
                                                                 Grid.Row="1"
                                                                 Text="{Binding UserMSSV, Mode=OneWay}"
                                                                 VerticalAlignment="Top"
                                                                 FontSize="13"
                                                                 Foreground="Gray" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Border>
                        </StackPanel>

                        <!--// navigation & Logout //-->
                        <Border Padding="15">
                            <Border CornerRadius="5" Background="White">
                                <StackPanel>
                                    <!--// Navigation //-->
                                    <Border CornerRadius="5" Background="White">
                                        <ListBox x:Name="lBoxNavigation"
                                                 SelectionMode="Single"
                                                 ItemsSource="{Binding NavigationItems,Mode=OneWay}"
                                                 SelectedItem="{Binding SelectedItem,Mode=TwoWay}"
                                                 Focusable="{Binding ElementName=LeftDrawer, Path=LeftDrawerOpened}">
                                            <ListBox.Styles>
                                                <Style Selector="ListBoxItem">
                                                    <Setter Property="Height" Value="40" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Margin" Value="0" />
                                                    <Setter Property="Cursor" Value="Hand" />
                                                </Style>

                                                <Style Selector="ListBoxItem:selected Border">
                                                    <Setter Property="Background" Value="#9ddcfa" />
                                                </Style>


                                            </ListBox.Styles>

                                            <ListBox.ItemTemplate>
                                                <DataTemplate x:DataType="{x:Type models:NavigationItem}">
                                                    <Grid ColumnDefinitions="7 5 auto 5 *">
                                                        <Grid.Styles>
                                                            <Style Selector="TextBlock">
                                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                            </Style>
                                                        </Grid.Styles>
                                                        <Border
                                                            IsVisible="{Binding IsSelected, RelativeSource={RelativeSource Mode=FindAncestor,AncestorType= ListBoxItem}}"
                                                            Grid.Column="0" CornerRadius="0 5 5 0" Background="Blue" />
                                                        <materialIcons:MaterialIcon Grid.Column="2" Height="25"
                                                                Width="25" Kind="{Binding Kind}" />
                                                        <TextBlock Grid.Column="5" Text="{Binding Title}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                            <!-- // Element Example // -->
                                            <!--<ListBox.Items>
											<ListBoxItem>
												<Grid ColumnDefinitions="7 5 auto 5 *">
													<Grid.Styles>
														<Style Selector="TextBlock">
															<Setter Property="VerticalAlignment" Value="Center"/>
														</Style>
													</Grid.Styles>
													<Border  Grid.Column="0" CornerRadius="0 5 5 0" Background="Blue"/>
													<materialIcons:MaterialIcon Grid.Column="2" Height="25" Width="25" Kind="Abacus"/>
													<TextBlock Grid.Column="5" Text="text"/>
												</Grid>
											</ListBoxItem>
										</ListBox.Items>-->
                                        </ListBox>
                                    </Border>


                                    <Border Padding="15">
                                        <Separator Height="2" />
                                    </Border>

                                    <!--// Logout Button //-->

                                    <Button x:Name="BtnLogout"
                                            Background="White"
                                            Height="50"
                                            Foreground="Black"
                                            VerticalContentAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Padding="0"
                                            Cursor="Hand">

                                        <Button.ContentTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="5"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch">

                                                    <Grid ColumnDefinitions="50 *">
                                                        <materialIcons:MaterialIcon
                                                            Grid.Column="0"
                                                            Kind="Logout" />

                                                        <TextBlock Grid.Column="1"
                                                                   Text="Đăng xuất"
                                                                   VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </Button.ContentTemplate>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Border>
                    </DockPanel>
                </controls:NavigationDrawer.LeftDrawerContent>

                <!--// Content //-->
                <controls:NavigationDrawer.Content>
                    <Border Padding="15 10 15 10">
                        <Grid RowDefinitions="auto *">
                            <!--// Title content //-->
                            <Grid Grid.Row="0" RowDefinitions="* auto" ColumnDefinitions="50 *">
                                <ToggleButton x:Name="ExpandToggleButton"
                                              Grid.Row="0"
                                              Grid.Column="0"
                                              Height="35"
                                              Width="35"
                                              HorizontalAlignment="Left"
                                              Content="{materialIcons:MaterialIconTextExt Kind=Menu,Size=25}" />

                                <TextBlock x:Name="txtTitle"
                                           Text="{Binding Title}"
                                           Grid.Row="0"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           FontWeight="Bold"
                                           FontSize="30" />
                                <Separator Grid.Row="1" Grid.ColumnSpan="2" />

                            </Grid>
                            <!--// Navigation content //-->
                            <rxui:RoutedViewHost Grid.Row="1" x:Name="PageRounter" Router="{Binding Router}" />
                        </Grid>
                    </Border>
                </controls:NavigationDrawer.Content>
            </controls:NavigationDrawer>
        </dialogHostAvalonia:DialogHost>
        
        <!-- // Timetable Information Dialog // -->
        <dialogHostAvalonia:DialogHost
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Identifier="Timetable"
            CloseOnClickAway="True"
            DisableOpeningAnimation="True"
            >
            <dialogHostAvalonia:DialogHost.PopupPositioner>
                <positioners:AlignmentDialogPopupPositioner
                    Margin="100"
                    />
            </dialogHostAvalonia:DialogHost.PopupPositioner>
            <dialogHostAvalonia:DialogHost.DataTemplates>
                <DataTemplate x:DataType="timetableViewModel:TimetableLayoutViewModel">
                    <timetableView:TimetableLayoutView/>
                </DataTemplate>
            </dialogHostAvalonia:DialogHost.DataTemplates>
        </dialogHostAvalonia:DialogHost>
    </Grid>
</rxui:ReactiveUserControl>