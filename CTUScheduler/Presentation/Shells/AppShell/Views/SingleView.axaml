<u:ReactiveUrsaView x:TypeArguments="vm:MainViewModel" 
                    xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                    x:CompileBindings="True"
                    x:DataType="vm:MainViewModel"
                    xmlns:u="https://irihi.tech/ursa"
                    xmlns:views="clr-namespace:CTUScheduler.Presentation.Shells.AppShell.Views"
                    xmlns:vm="clr-namespace:CTUScheduler.Presentation.Shells.AppShell.ViewModels"
                    Focusable="True"
                    IsTitleBarVisible="False"
                    x:Class="CTUScheduler.Presentation.Shells.AppShell.Views.SingleView">
    <u:ReactiveUrsaView.RightContent>
        <StackPanel Orientation="Horizontal">
            <u:IconButton
                Theme="{StaticResource BorderlessIconButton}"
                Classes="Tertiary"
                Icon="{StaticResource SemiIconGithubLogo}"
               />
            <u:ThemeToggleButton
                Mode="Controller" />
        </StackPanel>
    </u:ReactiveUrsaView.RightContent>
    <views:MainView/>
</u:ReactiveUrsaView>
