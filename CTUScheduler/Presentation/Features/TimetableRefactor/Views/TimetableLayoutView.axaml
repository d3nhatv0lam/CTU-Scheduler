<rxui:ReactiveUserControl
    x:Name="MainTimetableLayout"
    x:TypeArguments="vm:TimetableLayoutBaseViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
    xmlns:rxui="http://reactiveui.net"
    x:CompileBindings="True"
    Focusable="True"
    x:DataType="vm:TimetableLayoutBaseViewModel"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:vm="clr-namespace:CTUScheduler.Presentation.Features.TimetableRefactor.ViewModels"
    xmlns:timetableVm="clr-namespace:CTUScheduler.Presentation.Features.TimetableRefactor.Models"
    xmlns:views1="clr-namespace:CTUScheduler.Presentation.Features.TimetableRefactor.Views"
    x:Class="CTUScheduler.Presentation.Features.TimetableRefactor.Views.TimetableLayoutView">

    <rxui:ReactiveUserControl.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource SubTextColor}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style Selector="TextBlock.value">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{DynamicResource Grey}" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="Button.outline-primary">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12 8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.outline-primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="Button.icon-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>
        <Style Selector="Button.icon-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1A1f5ca9" />
        </Style>

        <Style Selector="Border.sidebar">
            <Setter Property="Grid.Row" Value="0" />
            <Setter Property="Grid.Column" Value="0" />
            <Setter Property="Grid.ColumnSpan" Value="2" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            <Setter Property="Background" Value="White" />
        </Style>
        <Style Selector="Border.content-area">
            <Setter Property="Grid.Row" Value="1" />
            <Setter Property="Grid.Column" Value="0" />
            <Setter Property="Grid.ColumnSpan" Value="2" />
            <Setter Property="Background" Value="{DynamicResource BaseBackgroundColor}" />
        </Style>

        <Style Selector="ScrollViewer.large Border.sidebar">
            <Setter Property="Grid.Row" Value="0" />
            <Setter Property="Grid.Column" Value="0" />
            <Setter Property="Grid.ColumnSpan" Value="1" />
            <Setter Property="Grid.RowSpan" Value="2" />
            <Setter Property="Width" Value="340" />
            <Setter Property="MinWidth" Value="340" />
            <Setter Property="MaxWidth" Value="340" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>
        <Style Selector="ScrollViewer.large Border.content-area">
            <Setter Property="Grid.Row" Value="0" />
            <Setter Property="Grid.Column" Value="1" />
            <Setter Property="Grid.ColumnSpan" Value="1" />
            <Setter Property="Grid.RowSpan" Value="2" />
        </Style>

        <Style Selector="ScrollViewer.large">
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
        </Style>
        <Style Selector="ScrollViewer:not(.large)">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style Selector="Border.unscheduled-card.cancelled">
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="SineEaseInOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.unscheduled-card.cancelled:pointerover">
            <Setter Property="Opacity" Value="1.0" />
        </Style>

        <Style Selector="Border.unscheduled-cancelled-overlay">
            <Setter Property="Opacity" Value="1.0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="SineEaseInOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.unscheduled-card:pointerover Border.unscheduled-cancelled-overlay">
            <Setter Property="Opacity" Value="0.05" />
        </Style>
    </rxui:ReactiveUserControl.Styles>

    <ScrollViewer x:Name="RootScroller" HorizontalScrollBarVisibility="Disabled">
        <Interaction.Behaviors>
            <AdaptiveBehavior>
                <AdaptiveClassSetter MinWidth="1100" MinWidthOperator="GreaterThanOrEqual" ClassName="large" />
            </AdaptiveBehavior>
        </Interaction.Behaviors>

        <Grid x:Name="ResponsiveLayout"
              RowDefinitions="Auto, *"
              ColumnDefinitions="Auto, *"
              Background="White"
              MaxWidth="{Binding $parent[ScrollViewer].Bounds.Width}">

            <Border Classes="sidebar">
                <Grid RowDefinitions="Auto, *, Auto">

                    <StackPanel Grid.Row="0" Margin="24, 24, 24, 0" Spacing="16">
                        <StackPanel>
                            <TextBlock Text="Chi tiết thời khóa biểu" FontSize="13"
                                       Foreground="{DynamicResource SubTextColor}" FontWeight="SemiBold" />

                            <Panel Margin="0,4,0,0">
                                <Grid ColumnDefinitions="*, Auto" IsVisible="{Binding !IsEditing}">

                                    <ScrollViewer Grid.Column="0"
                                                  MaxHeight="80"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">

                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Thời khóa biểu:"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Grey}"
                                                       Margin="0,0,0,4" />

                                            <TextBlock
                                                Text="{Binding Name}"
                                                FontSize="22" FontWeight="Bold"
                                                Foreground="{DynamicResource PrimaryBrush}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </ScrollViewer>

                                    <Button Grid.Column="1"
                                            Classes="icon-btn"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Top"
                                            Command="{Binding StartEditCommand}"
                                            ToolTip.Tip="Đổi tên thời khóa biểu">
                                        <icon:MaterialIcon Kind="Pencil" Width="20" Height="20"
                                                           Foreground="{DynamicResource PrimaryBrush}" />
                                    </Button>
                                </Grid>

                                <Grid ColumnDefinitions="*, Auto, Auto" IsVisible="{Binding IsEditing}">

                                    <TextBox Grid.Column="0"
                                             Text="{Binding TempName}"
                                             FontSize="18" FontWeight="Bold"
                                             Padding="8,4"
                                             MaxHeight="80"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             VerticalAlignment="Top"
                                             Background="{DynamicResource BaseBackgroundColor}"
                                             BorderThickness="1"
                                             BorderBrush="{DynamicResource PrimaryBrush}"
                                             CornerRadius="4" />

                                    <Button Grid.Column="1"
                                            Classes="icon-btn"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Top"
                                            Command="{Binding SaveCommand}"
                                            ToolTip.Tip="Lưu lại">
                                        <icon:MaterialIcon Kind="Check" Width="24" Height="24" Foreground="Green" />
                                    </Button>

                                    <Button Grid.Column="2"
                                            Classes="icon-btn"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Top"
                                            Command="{Binding CancelCommand}"
                                            ToolTip.Tip="Hủy bỏ">
                                        <icon:MaterialIcon Kind="Close" Width="24" Height="24"
                                                           Foreground="{DynamicResource RedColor}" />
                                    </Button>
                                </Grid>
                            </Panel>
                        </StackPanel>

                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto">
                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="Số môn học" Classes="label" />
                                <TextBlock
                                    Text="{Binding SubjectsCount}"
                                    Classes="value" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="Tổng tín chỉ" Classes="label" />
                                <TextBlock
                                    Text="{Binding TotalCredits}"
                                    Classes="value" />
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1">
                                <TextBlock Text="Cập nhật lần cuối" Classes="label" />
                                <TextBlock
                                    Text="{Binding LastUpdated.LocalDateTime, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}"
                                    FontSize="14"
                                    Foreground="{DynamicResource Grey}" />
                            </StackPanel>
                        </Grid>

                        <u:Divider Margin="0, 8, 0, 16" BorderBrush="{DynamicResource BorderColor}" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid RowDefinitions="Auto, Auto" Margin="24, 0, 24, 24">

                            <Grid Grid.Row="1" RowDefinitions="Auto, *">
                                <TextBlock Grid.Row="0" Text="Môn lịch tự sắp xếp" Classes="label"
                                           ToolTip.Tip="Lịch tự dàn xếp với giảng viên" Margin="0,0,0,8" />

                                <ItemsRepeater Grid.Row="1" ItemsSource="{Binding VisualizerVM.UnscheduledCourses}">
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="timetableVm:ScheduleGroupCellShared">

                                            <Border Background="Transparent" Padding="0,0,0,8">

                                                <Border Classes="unscheduled-card"
                                                        Classes.cancelled="{Binding IsCancelled}"
                                                        Background="{DynamicResource BaseBackgroundColor}"
                                                        CornerRadius="6"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Border Padding="12">
                                                            <Grid RowDefinitions="Auto, Auto, Auto">
                                                                <TextBlock Grid.Row="0"
                                                                           Text="{Binding NameConcat, Mode=OneTime}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                                           TextWrapping="Wrap"
                                                                           Margin="0,0,0,6" />

                                                                <Grid Grid.Row="1" ColumnDefinitions="Auto, *">
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{Binding Credits, StringFormat={}Tín chỉ: {0}, Mode=OneWay}"
                                                                               FontSize="12"
                                                                               Foreground="{DynamicResource Grey}"
                                                                               Margin="0,0,8,0" />
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding Lecturer, Mode=OneWay}"
                                                                               FontSize="12"
                                                                               Foreground="{DynamicResource Grey}"
                                                                               TextAlignment="Right"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               ToolTip.Tip="{Binding Lecturer, Mode=OneWay}" />
                                                                </Grid>

                                                                <Grid Grid.Row="2" Margin="0,12,0,0"
                                                                      RowDefinitions="Auto, Auto">
                                                                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto"
                                                                          Margin="0,0,0,4">
                                                                        <TextBlock Grid.Column="0" Text="Sĩ số"
                                                                                FontSize="11"
                                                                                Foreground="{DynamicResource SubTextColor}" />
                                                                        <TextBlock Grid.Column="1"
                                                                                Text="{Binding RemainingConcatTotalStudents}"
                                                                                FontSize="11" FontWeight="SemiBold"
                                                                                Foreground="{DynamicResource PrimaryBrush}" />
                                                                    </Grid>

                                                                    <ProgressBar Grid.Row="1"
                                                                            Height="4"
                                                                            MinWidth="0"
                                                                            HorizontalAlignment="Stretch"
                                                                            CornerRadius="2"
                                                                            Foreground="{DynamicResource SecondaryBrush}"
                                                                            Background="{DynamicResource BorderColor}"
                                                                            Minimum="0"
                                                                            Maximum="{Binding TotalStudents}"
                                                                            Value="{Binding RemainingStudents}" />
                                                                </Grid>
                                                            </Grid>
                                                        </Border>

                                                        <Border Classes="unscheduled-cancelled-overlay"
                                                                Background="{DynamicResource DarkOverlayColor}"
                                                                IsVisible="{Binding IsCancelled}"
                                                                ZIndex="10"
                                                                IsHitTestVisible="False">
                                                            <Border Background="{DynamicResource LightRedColor}"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Padding="16,6"
                                                                    CornerRadius="50">
                                                                <TextBlock Text="LỚP ĐÃ BỊ XÓA"
                                                                           Foreground="White"
                                                                           FontSize="12"
                                                                           FontWeight="Bold"
                                                                           LetterSpacing="0.5"
                                                                           VerticalAlignment="Center"
                                                                           HorizontalAlignment="Center" />
                                                            </Border>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </Grid>

                        </Grid>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            x:Name="ExportPanel"
                            Padding="24"
                            Background="White"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource BorderColor}">
                        <Grid ColumnDefinitions="*, *">
                            <Button Classes="outline-primary"
                                    Grid.Column="0" Margin="0,0,6,0"
                                    ToolTip.Tip="Sao chép ảnh thời khóa biểu vào Clipboard (Ctrl+V)"
                                    Command="{Binding CopyToClipboardCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <icon:MaterialIcon Kind="ImageOutline" Width="18" Height="18" />
                                    <TextBlock Text="Xuất Ảnh" VerticalAlignment="Center" FontWeight="Medium" />
                                </StackPanel>
                            </Button>

                            <Button Classes="outline-primary"
                                    Grid.Column="1" Margin="6,0,0,0"
                                    ToolTip.Tip="Xuất file Excel"
                                    Command="{Binding ExportToExcelCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <icon:MaterialIcon Kind="FileExcelOutline" Width="18" Height="18" />
                                    <TextBlock Text="Xuất Excel" VerticalAlignment="Center" FontWeight="Medium" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Classes="content-area">
                <Grid Margin="16, 16, 16, 16">
                    <views1:TimetableView DataContext="{Binding VisualizerVM}" />
                </Grid>
            </Border>

        </Grid>
    </ScrollViewer>
</rxui:ReactiveUserControl>