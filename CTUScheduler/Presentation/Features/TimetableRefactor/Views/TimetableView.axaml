<rxui:ReactiveUserControl
    x:TypeArguments="vm:TimetableViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
    xmlns:rxui="http://reactiveui.net"
    xmlns:vm="clr-namespace:CTUScheduler.Presentation.Features.TimetableRefactor.ViewModels"
    xmlns:models="clr-namespace:CTUScheduler.Presentation.Features.TimetableRefactor.Models"
    xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    x:DataType="vm:TimetableViewModel"
    x:CompileBindings="True"
    x:Class="CTUScheduler.Presentation.Features.TimetableRefactor.Views.TimetableView">

    <rxui:ReactiveUserControl.Styles>
        <Style Selector="Border.cell-container" x:DataType="models:ScheduleCellUi">
            <Setter Property="BorderThickness" Value="1"></Setter>
            <Setter Property="CornerRadius" Value="6"></Setter>
            <Setter Property="ClipToBounds" Value="True"></Setter>
            <Setter Property="Background" Value="{Binding Shared.BackgroundColor}"></Setter>
        </Style>

        <Style Selector="Border.card-content.cancelled">
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="SineEaseInOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.cell-container:pointerover Border.card-content.cancelled">
            <Setter Property="Opacity" Value="1.0" />
        </Style>

        <Style Selector="Border.cancelled-overlay">
            <Setter Property="Opacity" Value="1.0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="SineEaseInOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.cell-container:pointerover Border.cancelled-overlay">
            <Setter Property="Opacity" Value="0.05" />
        </Style>

        <Style Selector=":is(UserControl).preview :is(Control).detail">
            <Setter Property="IsVisible" Value="False" />
        </Style>

    </rxui:ReactiveUserControl.Styles>

    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Background="White">
        <Grid ColumnDefinitions="* 1 * 1 * 1 * 1 * 1 * 1 *"
              RowDefinitions="* 1 * * * * * 0.7* * * * *">

            <Grid.Styles>
                <Style Selector="Grid > TextBlock.head">
                    <Setter Property="HorizontalAlignment" Value="Center" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Foreground" Value="{DynamicResource Grey}" />
                    <Setter Property="FontFamily" Value="{StaticResource Text-Font}" />
                </Style>
                <Style Selector="Grid > Rectangle">
                    <Setter Property="Fill" Value="{DynamicResource BorderColor}" />
                </Style>
            </Grid.Styles>

            <Rectangle Grid.Row="0" Grid.Column="1" Grid.RowSpan="12" Width="1" />
            <Rectangle Grid.Row="0" Grid.Column="3" Grid.RowSpan="12" Width="1" />
            <Rectangle Grid.Row="0" Grid.Column="5" Grid.RowSpan="12" Width="1" />
            <Rectangle Grid.Row="0" Grid.Column="7" Grid.RowSpan="12" Width="1" />
            <Rectangle Grid.Row="0" Grid.Column="9" Grid.RowSpan="12" Width="1" />
            <Rectangle Grid.Row="0" Grid.Column="11" Grid.RowSpan="12" Width="1" />

            <Rectangle Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="13" Height="1" />

            <TextBlock Classes="head" Grid.Row="0" Grid.Column="0" Text="Thời khóa biểu" />
            <TextBlock Classes="head" Grid.Row="0" Grid.Column="2" Text="Thứ 2" />
            <TextBlock Classes="head" Grid.Row="0" Grid.Column="4" Text="Thứ 3" />
            <TextBlock Classes="head" Grid.Row="0" Grid.Column="6" Text="Thứ 4" />
            <TextBlock Classes="head" Grid.Row="0" Grid.Column="8" Text="Thứ 5" />
            <TextBlock Classes="head" Grid.Row="0" Grid.Column="10" Text="Thứ 6" />
            <TextBlock Classes="head" Grid.Row="0" Grid.Column="12" Text="Thứ 7" />

            <TextBlock Classes="head" Grid.Row="2" Grid.Column="0" Text="Tiết 1" />
            <TextBlock Classes="head" Grid.Row="3" Grid.Column="0" Text="Tiết 2" />
            <TextBlock Classes="head" Grid.Row="4" Grid.Column="0" Text="Tiết 3" />
            <TextBlock Classes="head" Grid.Row="5" Grid.Column="0" Text="Tiết 4" />
            <TextBlock Classes="head" Grid.Row="6" Grid.Column="0" Text="Tiết 5" />

            <TextBlock Classes="head" Grid.Row="8" Grid.Column="0" Text="Tiết 6" />
            <TextBlock Classes="head" Grid.Row="9" Grid.Column="0" Text="Tiết 7" />
            <TextBlock Classes="head" Grid.Row="10" Grid.Column="0" Text="Tiết 8" />
            <TextBlock Classes="head" Grid.Row="11" Grid.Column="0" Text="Tiết 9" />

            <Border Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="13" ZIndex="-1"
                    Background="{DynamicResource BaseBackgroundColor}" />

            <Grid Grid.Row="2" Grid.RowSpan="10" Grid.Column="2" Grid.ColumnSpan="11">
                <ItemsControl x:Name="ScheduleTable" ItemsSource="{Binding ScheduleCells, Mode=OneWay}" Padding="0">

                    <ItemsControl.Styles>
                        <Style Selector="ItemsControl ContentPresenter" x:DataType="{x:Type models:ScheduleCellUi}">
                            <Setter Property="Grid.Row" Value="{Binding Row}" />
                            <Setter Property="Grid.Column" Value="{Binding Column}" />
                            <Setter Property="Grid.RowSpan" Value="{Binding RowSpan}" />
                        </Style>
                    </ItemsControl.Styles>

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Grid RowDefinitions="* * * * * 0.7* * * * *" ColumnDefinitions="* * * * * *" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="{x:Type models:ScheduleCellUi}">

                            <Border Background="Transparent" Padding="4">

                                <Border Classes="cell-container">

                                    <Grid>
                                        <Border Classes="card-content"
                                                Classes.cancelled="{Binding Shared.IsCancelled}">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">

                                                <Grid Margin="10"
                                                      RowDefinitions="Auto,Auto,Auto,*,Auto">

                                                    <Border Grid.Row="0"
                                                            Background="{Binding Shared.TextColor}"
                                                            CornerRadius="50"
                                                            Padding="10,4"
                                                            HorizontalAlignment="Left"
                                                            Margin="0,0,0,8">

                                                        <WrapPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Shared.CourseCode}"
                                                                       Foreground="{Binding Shared.BackgroundColor}"
                                                                       FontSize="12"
                                                                       FontWeight="Bold" />
                                                            <TextBlock Text=" • "
                                                                       Foreground="{Binding Shared.BackgroundColor}"
                                                                       FontSize="12"
                                                                       FontWeight="Bold" />
                                                            <TextBlock
                                                                Text="{Binding Shared.Credits,StringFormat={}{0} TC}"
                                                                Foreground="{Binding Shared.BackgroundColor}"
                                                                FontSize="12"
                                                                FontWeight="Bold" />
                                                        </WrapPanel>
                                                    </Border>

                                                    <WrapPanel Grid.Row="1"
                                                               Classes="detail"
                                                               Orientation="Horizontal"
                                                               Margin="0,0,0,6">
                                                        <TextBlock
                                                            Text="{Binding Shared.Group,StringFormat={}Nhóm {0}}"
                                                            Foreground="{Binding Shared.SecondaryTextColor}"
                                                            FontSize="11"
                                                            TextWrapping="Wrap" />
                                                        <TextBlock Text=" - "
                                                                   Foreground="{Binding Shared.SecondaryTextColor}"
                                                                   FontSize="11" />
                                                        <TextBlock Text="{Binding Room,StringFormat={}P.{0}}"
                                                                   Foreground="{Binding Shared.SecondaryTextColor}"
                                                                   FontSize="11"
                                                                   TextWrapping="Wrap" />
                                                    </WrapPanel>

                                                    <TextBlock Grid.Row="2"
                                                               Text="{Binding Shared.CourseName_VN}"
                                                               FontWeight="Bold"
                                                               FontSize="13"
                                                               Foreground="{Binding Shared.TextColor}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,0,6" />

                                                    <Grid Grid.Row="3"
                                                          Classes="detail"
                                                          ColumnDefinitions="Auto,*"
                                                          Margin="0,0,0,6">
                                                        <icon:MaterialIcon Grid.Column="0"
                                                                           Kind="AccountOutline"
                                                                           Width="14"
                                                                           Height="14"
                                                                           Margin="0,0,4,0"
                                                                           Foreground="{Binding Shared.SecondaryTextColor}"
                                                                           VerticalAlignment="Top" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Shared.Lecturer}"
                                                                   FontSize="11"
                                                                   Foreground="{Binding Shared.SecondaryTextColor}"
                                                                   TextWrapping="Wrap" />
                                                    </Grid>

                                                    <StackPanel Grid.Row="4"
                                                                Spacing="4" VerticalAlignment="Top">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock Grid.Column="0"
                                                                       Text="Sĩ số"
                                                                       FontSize="11"
                                                                       FontWeight="Medium"
                                                                       Foreground="{Binding Shared.SecondaryTextColor}" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Shared.RemainingConcatTotalStudents}"
                                                                       FontSize="11"
                                                                       FontWeight="Bold"
                                                                       Foreground="{Binding Shared.TextColor}" />
                                                        </Grid>
                                                        <ProgressBar Height="4"
                                                                     MinWidth="0"
                                                                     HorizontalAlignment="Stretch"
                                                                     CornerRadius="50"
                                                                     Minimum="0"
                                                                     Maximum="{Binding Shared.TotalStudents}"
                                                                     Value="{Binding Shared.RemainingStudents}"
                                                                     Foreground="{Binding Shared.TextColor}"
                                                                     Background="#4D000000"
                                                                     BorderThickness="0" />
                                                    </StackPanel>
                                                </Grid>
                                            </ScrollViewer>
                                        </Border>

                                        <Border Classes="cancelled-overlay"
                                                Background="{DynamicResource DarkOverlayColor}"
                                                IsVisible="{Binding Shared.IsCancelled}"
                                                IsHitTestVisible="False">
                                            <Border Background="{DynamicResource LightRedColor}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Padding="14,6"
                                                    Opacity="0.8"
                                                    CornerRadius="50">
                                                <TextBlock Text="LỚP ĐÃ BỊ XÓA"
                                                           Foreground="White"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           LetterSpacing="0.5"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </Border>
                                        </Border>

                                    </Grid>
                                </Border>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </Border>

</rxui:ReactiveUserControl>