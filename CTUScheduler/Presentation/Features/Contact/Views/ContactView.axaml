<rxui:ReactiveUserControl
    x:TypeArguments="vm:ContactViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:rxui="http://reactiveui.net"
    xmlns:vm="clr-namespace:CTUScheduler.Presentation.Features.Contact.ViewModels;assembly=CTUScheduler"
    xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    x:DataType="vm:ContactViewModel"
    x:CompileBindings="True"
    x:Class="CTUScheduler.Presentation.Features.Contact.Views.ContactView">

    <UserControl.Styles>
        <Style Selector="Button.SocialButton">
            <Setter Property="Width" Value="45" />
            <Setter Property="Height" Value="45" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.3" Easing="CubicEaseOut" />
                    <BrushTransition Property="Background" Duration="0:0:0.25" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.SocialButton /template/ ContentPresenter">
            <Setter Property="BoxShadow" Value="none" />
        </Style>

        <Style Selector="Button.SocialButton:pointerover">
            <Setter Property="Width" Value="120" />
        </Style>

        <Style Selector="Button.SocialButton material|MaterialIcon.SocialIcon">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.SocialButton PathIcon.SocialIcon">
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
        
        <Style Selector="Button.SocialButton TextBlock.SocialText">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.SocialButton:pointerover material|MaterialIcon.SocialIcon">
            <Setter Property="Opacity" Value="0" />
        </Style>
        <Style Selector="Button.SocialButton:pointerover PathIcon.SocialIcon">
            <Setter Property="Opacity" Value="0" />
        </Style>
        <Style Selector="Button.SocialButton:pointerover TextBlock.SocialText">
            <Setter Property="Opacity" Value="1" />
        </Style>
        
        <Style Selector="Button.SocialButton /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="BoxShadow" Value="none" />
            <Setter Property="Background" Value="{TemplateBinding Background}" />
        </Style>

        <Style Selector="Button.SocialButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{TemplateBinding Background}" />
        </Style>

        <Style Selector="Button.SocialButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{TemplateBinding Background}" />
            <Setter Property="Opacity" Value="0.8" /> 
        </Style>

        <!-- Contributor Card Base and Hover Styling -->
        <Style Selector="Border.ContributorCard">
            <Setter Property="Background" Value="White" />
            <Setter Property="BoxShadow" Value="0 4 15 0 #0D000000" />
            <Setter Property="RenderTransform" Value="none" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.35" Easing="CubicEaseOut" />
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.35" Easing="CubicEaseOut" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.3" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
            <Style.Animations>
                <Animation Duration="0:0:0.65" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Border.ContributorCard:pointerover">
            <Setter Property="BorderBrush" Value="#00B0FF" />
            <Setter Property="RenderTransform" Value="translateY(-6px)" />
            <Setter Property="BoxShadow" Value="0 14 32 0 #1A000000" />
        </Style>

        <!-- Avatar Container Base & Hover Animation -->
        <Style Selector="Border.AvatarContainer">
            <Setter Property="RenderTransform" Value="none" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.35" Easing="CubicEaseOut" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.35" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.ContributorCard:pointerover Border.AvatarContainer">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}" />
            <Setter Property="RenderTransform" Value="scale(1.05)" />
        </Style>

        <!-- Page Title Animation -->
        <Style Selector="TextBlock.PageTitle">
            <Style.Animations>
                <Animation Duration="0:0:0.5" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Contributor Layout Positioning Styles -->
        <Style Selector="Grid.ContributorLayout > Border.AvatarContainer">
            <Setter Property="Grid.Row" Value="0" />
            <Setter Property="Grid.Column" Value="0" />
            <Setter Property="Grid.ColumnSpan" Value="2" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,20,0,10" />
        </Style>
        <Style Selector="Grid.ContributorLayout > Grid.InfoContainer">
            <Setter Property="Grid.Row" Value="1" />
            <Setter Property="Grid.Column" Value="0" />
            <Setter Property="Grid.ColumnSpan" Value="2" />
            <Setter Property="Margin" Value="15,0,15,20" />
            <Setter Property="MinWidth" Value="280" />
        </Style>

        <Style Selector="Grid.RootContainer.large Grid.ContributorLayout > Border.AvatarContainer">
            <Setter Property="Grid.Row" Value="0" />
            <Setter Property="Grid.Column" Value="0" />
            <Setter Property="Grid.RowSpan" Value="2" />
            <Setter Property="Grid.ColumnSpan" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="25" />
        </Style>
        <Style Selector="Grid.RootContainer.large Grid.ContributorLayout > Grid.InfoContainer">
            <Setter Property="Grid.Row" Value="0" />
            <Setter Property="Grid.Column" Value="1" />
            <Setter Property="Grid.RowSpan" Value="2" />
            <Setter Property="Grid.ColumnSpan" Value="1" />
            <Setter Property="Margin" Value="10,30,30,25" />
        </Style>
    </UserControl.Styles>

    <Grid Classes="RootContainer">
        <Interaction.Behaviors>
            <AdaptiveBehavior>
                <AdaptiveClassSetter MinWidth="800" MinWidthOperator="GreaterThanOrEqual" ClassName="large" />
            </AdaptiveBehavior>
        </Interaction.Behaviors>

        <ScrollViewer>
            <Grid Classes="main-grid" RowDefinitions="Auto, *" HorizontalAlignment="Center">

                <Border Grid.Row="0" Margin="20,20,20,10">
                    <TextBlock Classes="PageTitle"
                               Text="Đội ngũ phát triển"
                               FontFamily="{StaticResource Ctu-Title-Font}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryColor}"
                               HorizontalAlignment="Center" />
                </Border>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding Contributors}" Margin="10,0,10,20"
                              HorizontalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ContributorViewModel">
                            <Border Classes="ContributorCard" Margin="10" Background="White" CornerRadius="20"
                                    Padding="0" MaxWidth="650" BorderBrush="#E5E7EB" BorderThickness="1">
                                <Grid Classes="ContributorLayout" RowDefinitions="Auto, Auto"
                                      ColumnDefinitions="Auto, *">

                                    <!-- Avatar -->
                                    <Border Classes="AvatarContainer" Width="160" Height="160" CornerRadius="80"
                                            BorderBrush="#00B0FF" BorderThickness="4" ClipToBounds="True"
                                            Background="#F3F4F6">
                                        <Panel>
                                            <TextBlock Text="{Binding FallbackLetter}" FontSize="48" FontWeight="Bold"
                                                       Foreground="#9CA3AF"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />

                                            <Ellipse Width="152" Height="152">
                                                <Ellipse.Fill>
                                                    <ImageBrush Source="{Binding AvatarImage}" Stretch="UniformToFill" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </Panel>
                                    </Border>

                                    <!-- Info -->
                                    <Grid Classes="InfoContainer" RowDefinitions="Auto, *, Auto">
                                        <TextBlock Grid.Row="0" Text="{Binding Name}" FontSize="24" FontWeight="Bold"
                                                   Foreground="#1E5E9C" TextWrapping="Wrap" />

                                        <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="0,10,0,0">
                                            <TextBlock Text="{Binding Nickname, StringFormat='\{0\}'}"
                                                       FontSize="16" Foreground="#6B7280" FontWeight="Medium"
                                                       IsVisible="{Binding Nickname, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </StackPanel>

                                        <ItemsRepeater Grid.Row="2" ItemsSource="{Binding SocialLinks}"
                                                       Margin="0,15,0,0" HorizontalAlignment="Right"
                                                       VerticalAlignment="Bottom">
                                            <ItemsRepeater.Layout>
                                                <StackLayout Orientation="Horizontal" Spacing="8" />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="vm:SocialLinkItem">
                                                    <Button Classes="SocialButton"
                                                            Background="{Binding BackgroundColor}"
                                                            Command="{Binding $parent[UserControl].((vm:ContactViewModel)DataContext).OpenUrlCommand}"
                                                            CommandParameter="{Binding Url}">
                                                        <Panel>
                                                            <material:MaterialIcon Classes="SocialIcon"
                                                                    Kind="{Binding Icon}" Width="24" Height="24"
                                                                    Foreground="White"
                                                                    IsVisible="{Binding HasNormalIcon}" />
                                                            <PathIcon Classes="SocialIcon"
                                                                      Width="22" Height="22"
                                                                      Foreground="White"
                                                                      Data="{Binding CustomIconData}"
                                                                      IsVisible="{Binding HasCustomIcon}" />
                                                            <TextBlock Classes="SocialText" Text="{Binding Title}"
                                                                       Foreground="White" FontWeight="Bold"
                                                                       VerticalAlignment="Center"
                                                                       HorizontalAlignment="Center" />
                                                        </Panel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</rxui:ReactiveUserControl>