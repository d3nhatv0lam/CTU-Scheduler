<rxui:ReactiveUserControl
    x:TypeArguments="vm:HomeViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
    xmlns:rxui="http://reactiveui.net"
    x:DataType="vm:HomeViewModel"
    x:CompileBindings="True"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:vm="clr-namespace:CTUScheduler.Presentation.Features.Home.ViewModels;assembly=CTUScheduler"
    xmlns:model="clr-namespace:CTUScheduler.Core.Models.Academic.Curriculum.Registration"
    x:Class="CTUScheduler.Presentation.Features.Home.Views.HomeView">

    <Design.DataContext>
        <vm:HomeViewModel />
    </Design.DataContext>

    <rxui:ReactiveUserControl.Styles>
        <Style Selector="SelectableTextBlock">
            <Setter Property="SelectionForegroundBrush" Value="White" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        
        <Style Selector="Grid.main-grid">
            <Style Selector="^ > Border.Card">
                <Setter Property="Grid.Column" Value="0" />
                <Setter Property="Grid.ColumnSpan" Value="2" />
            </Style>
            <Style Selector="^ Border.card-item-1"><Setter Property="Grid.Row" Value="0" /></Style>
            <Style Selector="^ Border.card-item-2"><Setter Property="Grid.Row" Value="1" /></Style>
            <Style Selector="^ Border.card-item-3"><Setter Property="Grid.Row" Value="2" /></Style>
            <Style Selector="^ Border.card-item-4"><Setter Property="Grid.Row" Value="3" /></Style>
        </Style>

        <!-- Trạng thái màn hình lớn (large screen) -->
        <Style Selector="Grid.main-grid.large">
            <Style Selector="^ > Border.Card">
                <Setter Property="Grid.ColumnSpan" Value="1" />
            </Style>

            <Style Selector="^ > Border.card-item-1">
                <Setter Property="Grid.Row" Value="0" />
                <Setter Property="Grid.Column" Value="0" />
            </Style>
            <Style Selector="^ > Border.card-item-2">
                <Setter Property="Grid.Row" Value="0" />
                <Setter Property="Grid.Column" Value="1" />
            </Style>
            <Style Selector="^ > Border.card-item-3">
                <Setter Property="Grid.Row" Value="1" />
                <Setter Property="Grid.Column" Value="0" />
            </Style>
            <Style Selector="^ > Border.card-item-4">
                <Setter Property="Grid.Row" Value="1" />
                <Setter Property="Grid.Column" Value="1" />
            </Style>
        </Style>
        
        <!-- UI tĩnh của Card -->
        <Style Selector="Border.Card">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="25" />
            <Setter Property="BoxShadow" Value="0 4 15 0 #0D000000" />
        </Style>

        <Style Selector="TextBlock.CardTitle">
            <Setter Property="FontFamily" Value="{StaticResource Ctu-Title-Font}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}" />
            <Setter Property="Margin" Value="0,0,0,15" />
        </Style>
        
        <StyleInclude Source="avares://CTUScheduler/Presentation/Shared/Styles/Controls.axaml"></StyleInclude>
    </rxui:ReactiveUserControl.Styles>

    <Grid>
        <Border>
            <!-- Thêm x:Name="MainGrid" để điều khiển chia cột trong C# -->
            <Grid Classes="main-grid" ColumnSpacing="10"
                  RowSpacing="10"
                  ColumnDefinitions="2*, *"
                  RowDefinitions="Auto, Auto, Auto, Auto">
                <Interaction.Behaviors>
                    <AdaptiveBehavior>
                        <AdaptiveClassSetter MinWidth="1200" MinWidthOperator="GreaterThanOrEqual" ClassName="large" />
                    </AdaptiveBehavior>
                </Interaction.Behaviors>
                
                <!--// Card 1: Thông tin đăng ký //-->
                <Border Classes="Card card-item-1">
                    <Grid RowDefinitions="Auto, Auto, Auto">
                        <TextBlock Grid.Row="0" Classes="CardTitle" Text="Thông tin đăng ký" />
                        <u:Skeleton Grid.Row="1" IsLoading="{Binding IsLoading}" IsActive="True">
                            <TextBlock x:Name="txtRegistrationInfo" Classes="ContentText" Text="Học kỳ: ..."
                                       LineHeight="24" />
                        </u:Skeleton>
                        <u:Skeleton Grid.Row="2" Margin="0,25,0,0" IsLoading="{Binding IsLoading}" IsActive="True">
                            <ContentControl Content="{Binding RegistrationInfo.UserPeriod}">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate x:DataType="model:UserPeriodItem">
                                        <WrapPanel Margin="0,5,0,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,30,5">
                                                <TextBlock Text="Bắt đầu: " FontWeight="Bold" Classes="ContentText" />
                                                <TextBlock Text="{Binding StartDate, StringFormat='dd/MM/yyyy HH:mm'}" Classes="ContentText"
                                                           FontWeight="Bold" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="Kết thúc: " FontWeight="Bold" Classes="ContentText" />
                                                <TextBlock Text="{Binding EndDate, StringFormat='dd/MM/yyyy HH:mm'}" Classes="ContentText"
                                                           FontWeight="Bold" />
                                            </StackPanel>
                                        </WrapPanel>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                        </u:Skeleton>
                    </Grid>
                </Border>

                <!--// Card 2: Nhóm của bạn //-->
                <Border Classes="Card card-item-2">
                    <Grid RowDefinitions="Auto, *">
                        <TextBlock Grid.Row="0" Classes="CardTitle" Text="Nhóm của bạn" />
                        <u:Skeleton Grid.Row="1" IsLoading="{Binding IsLoading}" IsActive="True">
                            <ContentControl Content="{Binding RegistrationInfo.UserPeriod}">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate x:DataType="model:UserPeriodItem">
                                        <StackPanel>
                                            <TextBlock Text="{Binding AllowedGroupsDisplay, StringFormat='Nhóm \{0\}'}" FontSize="24"
                                                       FontWeight="Bold" Foreground="#111111" Margin="0,0,0,10" />
                                            <TextBlock
                                                Text="{Binding GroupDescription}"
                                                TextWrapping="WrapWithOverflow" Classes="ContentText"
                                                Foreground="#555555" Margin="0,0,0,15" />
                                            <TextBlock Text="{Binding Key}" Classes="ContentText"
                                                       Foreground="#777777" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                        </u:Skeleton>
                    </Grid>
                </Border>

                <!--// Card 3: Các nhóm đơn vị //-->
                <Border Classes="Card card-item-3">
                    <Grid RowDefinitions="Auto, *" ClipToBounds="True">
                        <TextBlock Grid.Row="0" Classes="CardTitle" Text="Các nhóm đơn vị" />
                        <u:Skeleton Grid.Row="1" IsLoading="{Binding IsLoading}" IsActive="True">
                            <DataGrid x:Name="dtgridGroupList" BorderBrush="#E5E7EB" BorderThickness="1"
                                      CanUserReorderColumns="False" CanUserSortColumns="False"
                                      CanUserResizeColumns="False"
                                      IsReadOnly="True" ColumnHeaderHeight="46" GridLinesVisibility="Horizontal"
                                      AutoGenerateColumns="False">
                                <DataGrid.Styles>
                                    <!-- <Style Selector="DataGridColumnHeader /template/ Rectangle#VerticalSeparator"> -->
                                    <!--     <Setter Property="IsVisible" Value="False" /> -->
                                    <!--     <Setter Property="Width" Value="0" /> -->
                                    <!-- </Style> -->
                                    <!-- <Style Selector="DataGridColumnHeader /template/ Grid > Border"> -->
                                    <!--     <Setter Property="BorderThickness" Value="0" /> -->
                                    <!-- </Style> -->
                                    <Style Selector="SelectableTextBlock">
                                        <Setter Property="TextWrapping" Value="WrapWithOverflow" />
                                        <Setter Property="FontSize" Value="14" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                    </Style>
                                    <Style Selector="DataGridCell">
                                        <Setter Property="Padding" Value="12,10" />
                                    </Style>
                                    <Style Selector="DataGridColumnHeader">
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="Background" Value="#F3F4F6" />
                                        <Setter Property="BorderThickness" Value="0" />
                                    </Style>
                                </DataGrid.Styles>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="Auto" MaxWidth="120">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="Nhóm" Margin="10,0" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="{x:Type model:GroupItem}">
                                                <SelectableTextBlock Text="{Binding Name}" FontWeight="Bold"
                                                                     Foreground="#111827" Margin="10,0" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="*">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="Các trường/khoa" />
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate x:DataType="{x:Type model:GroupItem}">
                                                <SelectableTextBlock Text="{Binding Description}" Foreground="#4B5563" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </u:Skeleton>
                    </Grid>
                </Border>

                <!--// Card 4: Lộ trình đăng ký học phần //-->
                <Border x:Name="Card4" Classes="Card card-item-4">
                    <Grid RowDefinitions="Auto, *">
                        <TextBlock Grid.Row="0" Classes="CardTitle" Text="Lộ trình đăng ký học phần" />
                        <u:Skeleton Grid.Row="1" IsLoading="{Binding IsLoading}" IsActive="True">
                            <u:Timeline Margin="15,0,0,0">
                                <u:Timeline.Styles>
                                    <Style Selector="u|TimelineItem /template/ TextBlock#PART_Time">
                                        <Setter Property="IsVisible" Value="False" />
                                    </Style>
                                </u:Timeline.Styles>
                                <u:TimelineItem Classes="Primary">
                                    <u:TimelineItem.Content>
                                        <Grid MaxWidth="480" Margin="0,0,45,25" RowDefinitions="Auto, Auto">
                                            <TextBlock Grid.Row="0" Text="Đăng ký học phần (đợt 1)" FontSize="16"
                                                       FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="1" Text="06/08/1999 - 03/02/2000" FontSize="14"
                                                       Foreground="#6B7280" />
                                        </Grid>
                                    </u:TimelineItem.Content>
                                </u:TimelineItem>
                                <u:TimelineItem Classes="Primary">
                                    <u:TimelineItem.Content>
                                        <Grid MaxWidth="480" Margin="0,0,45,25" RowDefinitions="Auto, Auto">
                                            <TextBlock Grid.Row="0" Text="Đăng ký học phần (đợt 1)" FontSize="16"
                                                       FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="1" Text="06/08/1999 - 03/02/2000" FontSize="14"
                                                       Foreground="#6B7280" />
                                        </Grid>
                                    </u:TimelineItem.Content>
                                </u:TimelineItem>
                                <u:TimelineItem Classes="Success">
                                    <u:TimelineItem.Content>
                                        <Grid MaxWidth="480" Margin="0,0,45,25" RowDefinitions="Auto, Auto">
                                            <TextBlock Grid.Row="0" Text="Đăng ký học phần (đợt 1)" FontSize="16"
                                                       FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="1" Text="06/08/1999 - 03/02/2000" FontSize="14"
                                                       Foreground="#6B7280" />
                                        </Grid>
                                    </u:TimelineItem.Content>
                                </u:TimelineItem>
                                <u:TimelineItem>
                                    <u:TimelineItem.Content>
                                        <Grid MaxWidth="480" Margin="0,0,45,25" RowDefinitions="Auto, Auto">
                                            <TextBlock Grid.Row="0" Text="Đăng ký học phần (đợt 1)" FontSize="16"
                                                       FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="1" Text="06/08/1999 - 03/02/2000" FontSize="14"
                                                       Foreground="#6B7280" />
                                        </Grid>
                                    </u:TimelineItem.Content>
                                </u:TimelineItem>
                            </u:Timeline>
                        </u:Skeleton>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</rxui:ReactiveUserControl>