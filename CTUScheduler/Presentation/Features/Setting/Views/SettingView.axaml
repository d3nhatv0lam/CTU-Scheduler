<rxui:ReactiveUserControl
			x:TypeArguments="vm:SettingViewModel"
			xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
			 xmlns:rxui="http://reactiveui.net"
			 xmlns:vm="clr-namespace:CTUScheduler.Presentation.Features.Setting.ViewModels"
			 xmlns:u="https://irihi.tech/ursa"
			 x:DataType="vm:SettingViewModel"
			 x:CompileBindings="True"
             x:Class="CTUScheduler.Presentation.Features.Setting.Views.SettingView">
	

	<Grid>
		<TextBlock Text="Setting view" FontSize="100"/>
		
		<u:Timeline Mode="Center">
			<u:TimelineItem Header="Lập trình mạng" Type="Success">
				<TextBlock Text="Phòng 101 - Thầy A (Nhớ mang laptop)" Classes="Tertiary"/>
			</u:TimelineItem>
			<u:TimelineItem Header="Giải lao" Type="Warning">
				<TextBlock Text="Canteen khu II" />
			</u:TimelineItem>
			<u:TimelineItem Header="Hệ điều hành" Type="Error">
				<TextBlock Text="Phòng máy 2 - Kiểm tra giữa kỳ" FontWeight="Bold" Foreground="Red"/>
			</u:TimelineItem>
		</u:Timeline>
	</Grid>
</rxui:ReactiveUserControl>
