<rxui:ReactiveUserControl
    x:TypeArguments="viewModels:TimetableManagerViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="550"
    xmlns:rxui="http://reactiveui.net"
    x:DataType="viewModels:TimetableManagerViewModel"
    x:CompileBindings="True"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:viewModels="clr-namespace:CTUScheduler.Presentation.Features.TimetableManager.ViewModels"
    xmlns:views="clr-namespace:CTUScheduler.Presentation.Features.TimetableManager.Views"
    xmlns:timetableViewModel="clr-namespace:CTUScheduler.Presentation.Features.TimetableRefactor.ViewModels"
    xmlns:views2="clr-namespace:CTUScheduler.Presentation.Features.TimetableRefactor.Views"
    x:Class="CTUScheduler.Presentation.Features.TimetableManager.Views.TimetableManagerView">

    <Design.DataContext>
        <viewModels:TimetableManagerViewModel />
    </Design.DataContext>

    <rxui:ReactiveUserControl.Styles>
        <StyleInclude Source="avares://CTUScheduler/Presentation/Shared/Styles/Controls.axaml" />

        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Text-Font}" />
        </Style>

        <Style Selector="TextBlock.Title">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Grey}" />
        </Style>

        <Style Selector="TextBlock.SubTitle">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="#a3a3a3" />
        </Style>

        <Style Selector="TextBlock.expired-save">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource RedColor}" />
            <Setter Property="Cursor" Value="Help" />
        </Style>

        <Style Selector="Button.btnTopAction /template/ ContentPresenter#PART_ContentPresenter,
                         Button.btnPrimary /template/ ContentPresenter#PART_ContentPresenter,
                         Button.btnSecondary /template/ ContentPresenter#PART_ContentPresenter,
                         Button.btnDanger /template/ ContentPresenter#PART_ContentPresenter,
                         Button.btnSuccess /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2" />
                    <BrushTransition Property="Foreground" Duration="0:0:0.2" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.btnTopAction">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12 6" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.btnTopAction:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BaseBackgroundColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
        </Style>
        <Style Selector="Button.btnTopAction:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Opacity" Value="0.7" />
        </Style>

        <Style Selector="Button.btnPrimary">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14 6" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.btnPrimary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.btnPrimary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>

        <Style Selector="Button.btnSecondary">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14 6" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.btnSecondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SecondaryBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.btnSecondary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Opacity" Value="0.8" />
        </Style>

        <Style Selector="Button.btnDanger">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{DynamicResource RedColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RedColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14 6" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.btnDanger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource RedColor}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.btnDanger:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Opacity" Value="0.8" />
        </Style>

        <Style Selector="Button.btnSuccess">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#107c41" />
            <Setter Property="BorderBrush" Value="#107c41" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14 6" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.btnSuccess:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#107c41" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.btnSuccess:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Opacity" Value="0.8" />
        </Style>

        <Style Selector="Border.MainCard">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            <Setter Property="BoxShadow" Value="0 4 16 0 #08000000" />
        </Style>

        <Style Selector="Border.TimetableCard">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="BoxShadow" Value="0 2 8 0 #0A000000" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.TimetableCard:pointerover">
            <Setter Property="BoxShadow" Value="0 4 16 0 #1A000000" />
            <Setter Property="RenderTransform" Value="scale(1.02)" />
        </Style>

        <Style Selector="TextBlock.TotalCount">
            <Setter Property="Foreground" Value="#a3a3a3" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style Selector="TextBlock.CardTitle">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Grey}" />
        </Style>

        <Style Selector="TextBlock.CardMeta">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#a3a3a3" />
        </Style>

        <Style Selector="TextBlock.EmptyStateTitle">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource Grey}" />
        </Style>

        <Style Selector="TextBlock.EmptyStateSubtitle">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#a3a3a3" />
        </Style>

        <!-- small screen -->
        <Style Selector="Grid.HeaderGrid > StackPanel.HeaderTitle">
            <Setter Property="Grid.Row" Value="0" />
            <Setter Property="Grid.Column" Value="0" />
            <Setter Property="Grid.ColumnSpan" Value="2" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style Selector="Grid.HeaderGrid > StackPanel.HeaderButtons">
            <Setter Property="Grid.Row" Value="1" />
            <Setter Property="Grid.Column" Value="0" />
            <Setter Property="Grid.ColumnSpan" Value="2" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0 10 0 0" />
        </Style>

        <!-- large screen -->
        <Style Selector="Grid.RootHeaderGrid.large Grid.HeaderGrid > StackPanel.HeaderTitle">
            <Setter Property="Grid.Row" Value="0" />
            <Setter Property="Grid.Column" Value="0" />
            <Setter Property="Grid.ColumnSpan" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style Selector="Grid.RootHeaderGrid.large Grid.HeaderGrid > StackPanel.HeaderButtons">
            <Setter Property="Grid.Row" Value="0" />
            <Setter Property="Grid.Column" Value="1" />
            <Setter Property="Grid.ColumnSpan" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0" />
        </Style>
    </rxui:ReactiveUserControl.Styles>

    <Grid RowDefinitions="Auto *" Classes="RootHeaderGrid">
        <Interaction.Behaviors>
            <AdaptiveBehavior>
                <AdaptiveClassSetter MinWidth="850" MinWidthOperator="GreaterThanOrEqual" ClassName="large" />
            </AdaptiveBehavior>
        </Interaction.Behaviors>

        <!-- Header -->
        <Grid Grid.Row="0" Classes="HeaderGrid" Margin="12 10" RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto">
            <StackPanel Classes="HeaderTitle" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Classes="Title" Text="Quản lý thời khóa biểu" />
                <TextBlock Classes="SubTitle" Text="Lần cuối lưu dữ liệu:" Margin="16 0 0 4" VerticalAlignment="Bottom" />
                <TextBlock x:Name="txtLastSaved" Classes="SubTitle" Margin="4 0 0 4" VerticalAlignment="Bottom" />

                <TextBlock Classes="expired-save"
                           IsVisible="{Binding IsExpiredSaved}"
                           Text="Lưu trữ không phù hợp với học kỳ"
                           VerticalAlignment="Bottom"
                           Margin="16 0 0 4">
                    <ToolTip.Tip>
                        <StackPanel Width="300">
                            <TextBlock TextWrapping="WrapWithOverflow"
                                       Text="Bạn sẽ chỉ có thể xem lại các thời khóa biểu của các học kỳ trước, không thể cập nhật hay thêm thời khóa hiểu nữa!" />
                        </StackPanel>
                    </ToolTip.Tip>
                </TextBlock>
            </StackPanel>

            <StackPanel Classes="HeaderButtons" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <!--// load data button //-->
                <Button x:Name="btnLoad" Classes="btnTopAction">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <materialIcons:MaterialIcon Kind="Upload" Width="16" Height="16" />
                        <TextBlock VerticalAlignment="Center" Text="Tải lên" />
                    </StackPanel>
                    <ToolTip.Tip>
                        <TextBlock Text="Nạp dữ liệu của bạn lên ứng dụng!" />
                    </ToolTip.Tip>
                    <Interaction.Behaviors>
                        <ButtonOpenFilePickerBehavior
                            Title="Load dữ liệu"
                            AllowMultiple="False"
                            FileTypeFilter="JSON Files|*.json"
                            Command="{Binding LoadScheduleCommand}">
                        </ButtonOpenFilePickerBehavior>
                    </Interaction.Behaviors>
                </Button>

                <!--// download data button //-->
                <Button x:Name="btnSave" Classes="btnTopAction">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <materialIcons:MaterialIcon Kind="Download" Width="16" Height="16" />
                        <TextBlock VerticalAlignment="Center" Text="Tải xuống" />
                    </StackPanel>
                    <ToolTip.Tip>
                        <TextBlock Text="Tải dữ liệu về máy của bạn!" />
                    </ToolTip.Tip>
                    <Interaction.Behaviors>
                        <ButtonSaveFilePickerBehavior
                            Title="Load dữ liệu"
                            FileTypeChoices="JSON Files|*.json"
                            SuggestedFileName="Thời khóa biểu - CTU Scheduler"
                            Command="{Binding SaveScheduleCommand}">
                        </ButtonSaveFilePickerBehavior>
                    </Interaction.Behaviors>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Classes="MainCard" Margin="8 0 8 8">
            <Grid RowDefinitions="Auto *">
                <Grid Grid.Row="0" Margin="16 16 16 4" ColumnDefinitions="* Auto">
                    <WrapPanel Grid.Column="0" Orientation="Horizontal">
                        <WrapPanel.Styles>
                            <Style Selector="Button">
                                <Setter Property="Margin" Value="0 0 10 8" />
                            </Style>
                        </WrapPanel.Styles>

                        <Button x:Name="btnAddTables"
                                Classes="btnPrimary"
                                Command="{Binding ShowAddCourseDialogCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <materialIcons:MaterialIcon Kind="Plus" Height="16" Width="16" />
                                <TextBlock VerticalAlignment="Center" Text="Thêm thời khóa biểu" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnReloadTableData"
                                Classes="btnSecondary"
                                Command="{Binding ReloadAllTimetableCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <materialIcons:MaterialIcon Kind="Reload" Height="16" Width="16" />
                                <TextBlock VerticalAlignment="Center" Text="Cập nhật thông tin học phần" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnDeleteTables"
                                Classes="btnDanger"
                                Command="{Binding DeleteSelectedTimetablesCommand}"
                                IsVisible="{Binding HasSelectedTimetable}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <materialIcons:MaterialIcon Kind="Delete" Height="16" Width="16" />
                                <TextBlock VerticalAlignment="Center" Text="Xóa thời khóa biểu" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnExportSelectedTables"
                                Classes="btnSuccess"
                                Command="{Binding ExportSelectedTimetablesCommand}"
                                IsVisible="{Binding HasSelectedTimetable}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <materialIcons:MaterialIcon Kind="FileExcel" Height="16" Width="16" />
                                <TextBlock VerticalAlignment="Center" Text="Xuất Excel" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>

                    <TextBlock Grid.Column="1"
                               x:Name="txtTotalTable"
                               Classes="TotalCount"
                               VerticalAlignment="Top"
                               Margin="0 6 0 0"
                               Text="{Binding TimetableLayoutsCount, Mode=OneWay, StringFormat={}{0} Thời khóa biểu}" />
                </Grid>

                <ScrollViewer Grid.Row="1" Margin="16 0 16 16" HorizontalScrollBarVisibility="Disabled">
                    <Panel>
                        <ItemsRepeater x:Name="itmRptTables"
                                       ItemsSource="{Binding TimetableLayouts, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MinRowSpacing="24"
                                                   MinColumnSpacing="24"
                                                   ItemsJustification="SpaceEvenly" />
                            </ItemsRepeater.Layout>

                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="timetableViewModel:TimetableLayoutBaseViewModel">
                                    <Border Classes="TimetableCard" Width="260" Height="248">
                                        <Grid RowDefinitions="Auto Auto Auto Auto *">
                                            <!-- Checkbox/Select -->
                                            <CheckBox Grid.Row="0"
                                                      IsChecked="{Binding IsSelected}"
                                                      Content="Chọn" />

                                            <!-- Title / Name -->
                                            <TextBlock Grid.Row="1"
                                                       Classes="CardTitle"
                                                       Text="{Binding Name, StringFormat=Thời khóa biểu: {0}}" />

                                            <TextBlock Grid.Row="2" Height="4" />

                                            <!-- Last Updated -->
                                            <TextBlock Grid.Row="3"
                                                       Classes="CardMeta"
                                                       Text="{Binding LastUpdated.LocalDateTime, Mode=OneWay, StringFormat='Lần cuối cập nhật: \{0:dd/MM/yyyy HH:mm:ss\}'}" />

                                            <!-- Image Preview and Click area -->
                                            <Grid Grid.Row="4" Margin="0 8 0 0">
                                                <Border CornerRadius="6" ClipToBounds="True"
                                                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                                    <Viewbox Stretch="Uniform">
                                                        <Image Source="{Binding PreviewImage}"
                                                               Width="600"
                                                               Height="375"
                                                               RenderOptions.BitmapInterpolationMode="HighQuality" />
                                                    </Viewbox>
                                                </Border>

                                                <!-- Open details command button overlaid -->
                                                <Button Background="Transparent"
                                                        Classes="ripple"
                                                        Padding="0"
                                                        BorderThickness="0"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        Cursor="Hand"
                                                        Command="{Binding Path=((viewModels:TimetableManagerViewModel)DataContext).ShowTimetableDetailsCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=views:TimetableManagerView}}"
                                                        CommandParameter="{Binding .}">
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <!-- Empty state popup -->
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Background="Transparent"
                                    IsHitTestVisible="False"
                                    IsVisible="{Binding IsEmptyTimetableLayouts}"
                                    Spacing="12">
                            <Image Source="/Assets/Images/Course/EmptyScheduleTable.png" Stretch="None" />
                            <TextBlock Text="Thêm thời khóa biểu của bạn!" Classes="EmptyStateTitle" />
                            <TextBlock Text="Dễ lắm hehe" Classes="EmptyStateSubtitle" />
                        </StackPanel>
                    </Panel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</rxui:ReactiveUserControl>