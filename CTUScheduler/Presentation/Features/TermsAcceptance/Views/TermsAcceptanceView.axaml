<rxui:ReactiveUserControl x:TypeArguments="vm:TermsAcceptanceViewModel"
                          xmlns="https://github.com/avaloniaui"
                          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                          mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
                          xmlns:rxui="http://reactiveui.net"
                          Background="Transparent"
                          xmlns:md="https://github.com/whistyun/Markdown.Avalonia.Tight"
                          x:CompileBindings="True"
                          x:DataType="vm:TermsAcceptanceViewModel"
                          xmlns:vm="clr-namespace:CTUScheduler.Presentation.Features.TermsAcceptance.ViewModels"
                          x:Class="CTUScheduler.Presentation.Features.TermsAcceptance.Views.TermsAcceptanceView"
                          MaxWidth="620"
                          MaxHeight="750">

    <Border Background="{DynamicResource SemiColorBackground0}"
            BorderBrush="{DynamicResource SemiColorBorder}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="24,20,24,20"
            MaxWidth="620"
            MaxHeight="750">
        
        <Grid RowDefinitions="Auto, *, Auto">
            
            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,12">
                <TextBlock Text="Điều khoản sử dụng" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource SemiColorText0}"/>
                <Separator Height="1" Background="{DynamicResource SemiColorBorder}"/>
            </StackPanel>

            <!-- Content -->
            <Border Grid.Row="1" 
                    Background="{DynamicResource SemiColorBackground1}" 
                    CornerRadius="8" 
                    Padding="12,8">
                <md:MarkdownScrollViewer Source="avares://CTUScheduler/Assets/Docs/TERMS_SHORT.md"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"/>
            </Border>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Spacing="12" Margin="0,16,0,0">
                <Separator Height="1" Background="{DynamicResource SemiColorBorder}"/>
                
                <CheckBox Content="Tôi đã đọc, hiểu và đồng ý với các điều khoản trên" 
                          IsChecked="{Binding IsAgreed}" 
                          HorizontalAlignment="Left"
                          FontSize="12"/>
                
                <Grid ColumnDefinitions="*, *">
                    <Button Grid.Column="0"
                            Content="Tôi không đồng ý (Thoát)"
                            Command="{Binding DeclineCommand}"
                            Theme="{DynamicResource BorderedButton}"
                            Classes="Warning"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,0,8,0"
                            Padding="0,10"/>
                    
                    <Button Grid.Column="1"
                            Content="Tôi đã đọc và Chấp nhận"
                            Command="{Binding AcceptCommand}"
                            Theme="{DynamicResource SolidButton}"
                            Classes="Primary"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            FontWeight="SemiBold"
                            Margin="8,0,0,0"
                            Padding="0,10"/>
                </Grid>
            </StackPanel>

        </Grid>
    </Border>
</rxui:ReactiveUserControl>