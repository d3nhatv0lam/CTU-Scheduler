<rxui:ReactiveUserControl
    x:TypeArguments="viewModels:TimetableSchedulerViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="500"
    xmlns:rxui="http://reactiveui.net"
    x:DataType="viewModels:TimetableSchedulerViewModel"
    x:CompileBindings="True"
    xmlns:u="https://irihi.tech/ursa"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:models="clr-namespace:CTUScheduler.Presentation.Features.Scheduling.ViewModels.Components"
    xmlns:viewModels="clr-namespace:CTUScheduler.Presentation.Features.Scheduling.ViewModels.Steps"
    xmlns:views="clr-namespace:CTUScheduler.Presentation.Features.Scheduling.Views.Steps"
    xmlns:timetableModel="clr-namespace:CTUScheduler.Presentation.Shared.Models"
    xmlns:paginationViews="clr-namespace:CTUScheduler.Presentation.Features.Pagination.Views"
    xmlns:schedulingModels="clr-namespace:CTUScheduler.Presentation.Features.Scheduling.Models"
    x:Class="CTUScheduler.Presentation.Features.Scheduling.Views.Steps.TimetableSchedulerView">

    <rxui:ReactiveUserControl.Styles>
        <StyleInclude Source="avares://CTUScheduler/Presentation/Shared/Styles/Controls.axaml" />
        <StyleInclude Source="avares://CTUScheduler/Presentation/Features/Scheduling/Shared/Styles/controls.axaml" />

        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Text-Font}" />
        </Style>

        <Style Selector="TextBlock.Title">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
        </Style>

        <Style Selector="TextBlock.SubTitle">
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Margin" Value="12 0 0 4" />
            <Setter Property="TextAlignment" Value="DetectFromContent" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiLight" />
            <Setter Property="Foreground" Value="{StaticResource DisableColor}" />
        </Style>

        <Style Selector="Border.Card">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="BoxShadow" Value="0 4 15 0 #0D000000" />
        </Style>

        <Style Selector="Button.btnCreateSchedule">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="14 6" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.btnCreateSchedule:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonHoverBrush}" />
            <Setter Property="TextElement.Foreground" Value="White" />
        </Style>
        <Style Selector="Button.btnCreateSchedule:disabled">
            <Setter Property="Background" Value="{StaticResource DisableColor}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="Border.Separator">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{StaticResource BorderColor}" />
            <Setter Property="Margin" Value="10 0" />
        </Style>

        <Style Selector="Border.CourseItem">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10 8" />
            <Setter Property="Margin" Value="0 4" />
        </Style>

        <Style Selector="TextBlock.CourseCode">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource Grey}" />
        </Style>
        <Style Selector="Border.CreditBadge">
            <Setter Property="Background" Value="{StaticResource BaseBackgroundColor}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="6 2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.CreditText">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
        </Style>
        <Style Selector="TextBlock.GroupCount">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource DisableColor}" />
            <Setter Property="Margin" Value="0 2 0 4" />
        </Style>

        <Style Selector="StackPanel.locked">
            <Setter Property="IsHitTestVisible" Value="False" />
            <Style Selector="^ RadioButton.rd-locked /template/ Ellipse#OuterEllipse">
                <Setter Property="Fill" Value="{StaticResource RedColor}" />
                <Setter Property="Stroke" Value="{StaticResource RedColor}" />
            </Style>
        </Style>

        <Style Selector="ComboBox.CourseCombo">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style Selector="Border.TimetableCard">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="BoxShadow" Value="0 2 8 0 #0A000000" />
            <Setter Property="Width" Value="260" />
            <Setter Property="Height" Value="248" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.TimetableCard:pointerover">
            <Setter Property="BoxShadow" Value="0 4 16 0 #1A000000" />
            <Setter Property="RenderTransform" Value="scale(1.02)" />
        </Style>

        <Style Selector="TextBlock.ScoreText">
            <Setter Property="Foreground" Value="{StaticResource RedColor}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="paginationViews|PaginationView.pagination">
            <Setter Property="Height" Value="35" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0.15" Easing="CubicEaseInOut" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="paginationViews|PaginationView.pagination:pointerover">
            <Setter Property="Opacity" Value="1" />
        </Style>
    </rxui:ReactiveUserControl.Styles>

    <Grid ColumnDefinitions="0.22* 0.015* 0.5*">
        <Border Grid.Column="0" Padding="0 3">
            <Border Classes="CornerBorder">
                <Grid RowDefinitions="auto auto auto *" ClipToBounds="True">
                    <TextBlock
                        Grid.Row="0"
                        Classes="Title"
                        Text="Sắp xếp thời khóa biểu"
                        HorizontalAlignment="Left"
                        Margin="12 8 12 4"
                        TextWrapping="WrapWithOverflow" />

                    <Grid Grid.Row="1" Margin="12 8 12 8">
                        <ComboBox Classes="CourseCombo"
                                  SelectedItem="{Binding SelectedPreset}"
                                  ItemsSource="{Binding Presets, Mode=OneWay}"
                                  ToolTip.Tip="{Binding SelectedPreset.Description}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="schedulingModels:SchedulingPreset">
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                ToolTip.Tip="{Binding Description}">
                                        <TextBlock Text="{Binding Icon}" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Tiêu chí ưu tiên"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Background="White"
                                   Padding="4 0"
                                   Margin="10 -7 0 0"
                                   VerticalAlignment="Top"
                                   HorizontalAlignment="Left"
                                   Foreground="{StaticResource PrimaryBrush}" />
                    </Grid>

                    <Border Grid.Row="2" Classes="Separator" />

                    <Border Grid.Row="3"
                            Padding="8 4"
                            ClipToBounds="True">
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                            <ItemsRepeater
                                ItemsSource="{Binding SchedulingCourseCoordinatorVM.SchedulingCourses}">

                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:SchedulingCourseViewModel}">
                                        <Border Classes="CourseItem">
                                            <StackPanel Spacing="2">
                                                <Grid ColumnDefinitions="* auto">
                                                    <TextBlock Grid.Column="0" Classes="CourseCode"
                                                               TextTrimming="CharacterEllipsis">
                                                        <Run Text="{Binding Item.Code, Mode=OneTime}" />
                                                        <Run Text="-" />
                                                        <Run Text="{Binding Item.Name_VN, Mode=OneTime}" />
                                                    </TextBlock>
                                                    <Border Grid.Column="1" Classes="CreditBadge" Margin="6 0 0 0">
                                                        <TextBlock Classes="CreditText"
                                                                   Text="{Binding Item.Credits, Mode=OneTime, StringFormat={}{0} TC}" />
                                                    </Border>
                                                </Grid>

                                                <TextBlock Classes="GroupCount"
                                                           Text="{Binding Item.Sections.Count, Mode=OneTime, StringFormat=Số lượng nhóm đã chọn: {0}}" />

                                                <StackPanel
                                                    Classes.locked="{Binding IsLocked}"
                                                    Orientation="Horizontal"
                                                    Spacing="4">
                                                    <RadioButton
                                                        Classes="rd-locked"
                                                        IsChecked="{Binding IsMainCourse}"
                                                        Content="Môn chính" />
                                                    <RadioButton
                                                        IsChecked="{Binding IsMainCourse,Converter={x:Static BoolConverters.Not}}"
                                                        Content="Môn thay thế" />
                                                </StackPanel>

                                                <Border
                                                    Classes="height-transition"
                                                    Classes.hidden="{Binding IsMainCourse}"
                                                    Classes.show="{Binding !IsMainCourse}"
                                                    Padding="0 4 0 0">
                                                    <ComboBox Classes="CourseCombo"
                                                              SelectedItem="{Binding SelectedReplacement}"
                                                              ItemsSource="{Binding ReplacementOptions,Mode=OneWay}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate
                                                                x:DataType="{x:Type models:SchedulingCourseViewModel}">
                                                                <TextBlock>
                                                                    <Run
                                                                        Text="{Binding Item.Code,Mode=OneTime}">
                                                                    </Run>
                                                                    <Run Text="-" />
                                                                    <Run
                                                                        Text="{Binding Item.Name_VN, Mode=OneTime}" />
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <Border Grid.Column="2" Padding="0 3">
            <Border Classes="CornerBorder">
                <Grid RowDefinitions="auto auto *">
                    <DockPanel Grid.Row="0" LastChildFill="False" Margin="12 8">
                        <TextBlock
                            DockPanel.Dock="Left"
                            Classes="Title"
                            Text="Thời Khóa Biểu"
                            HorizontalAlignment="Left" />
                        <TextBlock DockPanel.Dock="Left"
                                   Classes="SubTitle">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Đã chọn {0}/{1} thời khóa biểu">
                                    <Binding Path="PaginationTimeTableViewModel.SelectedItemCount" Mode="OneWay" />
                                    <Binding Path="PaginationTimeTableViewModel.MaxItemCanSelect" Mode="OneWay" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <Button
                            DockPanel.Dock="Right"
                            Classes="btnCreateSchedule"
                            x:Name="btnAddTimeTable"
                            Command="{Binding GenerateTimeTableCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <materialIcons:MaterialIcon Kind="CalendarPlus" Width="16" Height="16" />
                                <TextBlock Text="Tạo thời khóa biểu" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </DockPanel>

                    <Border Grid.Row="1" Classes="Separator" />

                    <Border Grid.Row="2" Padding="8" ClipToBounds="False">
                        <Grid>
                            <ScrollViewer>
                                <Border>
                                    <ItemsRepeater ClipToBounds="False"
                                                   ItemsSource="{Binding PaginationTimeTableViewModel.PagedData}">
                                        <ItemsRepeater.Layout>
                                            <UniformGridLayout
                                                MinRowSpacing="30"
                                                MinColumnSpacing="30"
                                                ItemsJustification="SpaceEvenly">
                                            </UniformGridLayout>
                                        </ItemsRepeater.Layout>

                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="timetableModel:SelectableTimetableLayout">
                                                <Border Classes="TimetableCard">
                                                    <Grid
                                                        RowDefinitions="auto auto auto auto *">
                                                        <CheckBox Grid.Row="0"
                                                                  IsEnabled="{Binding IsEnabled}"
                                                                  IsChecked="{Binding IsSelected}"
                                                                  Content="Chọn" />
                                                        <TextBlock Grid.Row="1"
                                                                   FontSize="12"
                                                                   Text="{Binding Item.SubjectsCount, StringFormat=Số môn học: {0}}" />
                                                        <TextBlock Grid.Row="2"
                                                                   FontSize="12"
                                                                   Text="{Binding Item.TotalCredits,StringFormat=Số tín chỉ: {0}}" />
                                                        <TextBlock Grid.Row="3"
                                                                   Classes="ScoreText"
                                                                   Text="{Binding Item.TotalScore, StringFormat=Điểm đánh giá: {0:F2}}" />

                                                        <Grid Grid.Row="4">
                                                            <Border>
                                                                <Viewbox Stretch="Uniform">
                                                                    <Image Source="{Binding Item.PreviewImage}"
                                                                           Width="600"
                                                                           Height="375"
                                                                           RenderOptions.BitmapInterpolationMode="HighQuality" />
                                                                </Viewbox>
                                                            </Border>

                                                            <Button Classes="ripple"
                                                                    Background="Transparent"
                                                                    HorizontalAlignment="Stretch"
                                                                    VerticalAlignment="Stretch"
                                                                    Padding="0"
                                                                    BorderThickness="0"
                                                                    Command="{Binding Path= ((viewModels:TimetableSchedulerViewModel)DataContext).ShowTimetableDetailsCommand, RelativeSource={RelativeSource  Mode=FindAncestor, AncestorType=views:TimetableSchedulerView}}"
                                                                    CommandParameter="{Binding .}">
                                                            </Button>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </Border>
                            </ScrollViewer>
                            <paginationViews:PaginationView
                                IsVisible="{Binding TotalPages}"
                                DataContext="{Binding PaginationTimeTableViewModel}"
                                Classes="pagination">
                            </paginationViews:PaginationView>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</rxui:ReactiveUserControl>