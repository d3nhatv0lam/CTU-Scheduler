<rxui:ReactiveUserControl
    x:TypeArguments="viewModels:SchedulingShellViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
    xmlns:rxui="http://reactiveui.net"
    x:DataType="viewModels:SchedulingShellViewModel"
    x:CompileBindings="True"
    xmlns:controls="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:viewModels="clr-namespace:CTUScheduler.Presentation.Features.Scheduling.Shells.ViewModels"
    x:Class="CTUScheduler.Presentation.Features.Scheduling.Shells.Views.SchedulingShellView">

    <Design.DataContext>
        <viewModels:SchedulingShellViewModel />
    </Design.DataContext>

    <controls:Card
        Padding="0"
        Margin="0">
        <Grid RowDefinitions="* 35">
            <!--// main View //-->
            <rxui:ViewModelViewHost Grid.Row="0"
                                    ViewModel="{Binding CurrentWizardStep}"
                                    x:Name="vmRounter" />
            <!--// Button navigate //-->
            <DockPanel Grid.Row="1" LastChildFill="False">
                <DockPanel.Styles>
                    <Style Selector="Button">
                        <Setter Property="Width" Value="100" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="5 0 10 0" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="VerticalAlignment" Value="Stretch" />
                    </Style>
                </DockPanel.Styles>
                <Button x:Name="btnNext"
                        DockPanel.Dock="Right"
                        Content="{Binding BtnNextContent}"
                        Command="{Binding NavigateNextCommand}" />
                <Button x:Name="btnBack"
                        DockPanel.Dock="Right"
                        Content="Quay lại"
                        Command="{Binding NavigateBackCommand}" />
            </DockPanel>
        </Grid>
    </controls:Card>


</rxui:ReactiveUserControl>