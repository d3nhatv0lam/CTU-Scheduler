<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:assists="using:CTUScheduler.Presentation.Shared.Styles.Assists"
        xmlns:ripple="clr-namespace:CTUScheduler.Presentation.Shared.Styles.Ripple">

    <Design.PreviewWith>
        <Border Padding="20">
            <Grid>
                <Button Classes="ripple" 
                        HorizontalAlignment="Stretch" 
                        VerticalAlignment="Stretch"
                        Cursor="Hand"
                        Background="OliveDrab"
                        CornerRadius="10"
                        assists:ShadowAssist.ShadowDepth="Depth2">
                    hehe
                </Button>
            </Grid>
        </Border>
    </Design.PreviewWith>

    <Style Selector="Button.ripple">
        <Setter Property="Background" Value="#6200EE" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="CornerRadius" Value="6"></Setter>
        <Setter Property="assists:ShadowAssist.ShadowDepth" Value="Depth2" />

        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_RootBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        assists:ShadowAssist.ShadowDepth="{TemplateBinding assists:ShadowAssist.ShadowDepth}">

                    <Border.Transitions>
                        <Transitions>
                            <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2" Easing="CircularEaseOut" />
                        </Transitions>
                    </Border.Transitions>

                    <Panel>
                        <Border Name="PART_HoverEffect"
                                Background="White"
                                Opacity="0"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" />
                                </Transitions>
                            </Border.Transitions>
                        </Border>

                        <ripple:RippleEffect Name="PART_Ripple"
                                             CornerRadius="{TemplateBinding CornerRadius}"
                                             RippleFill="White"
                                             ClipToBounds="True">

                            <!-- LỚP 4: Nội dung chữ -->
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              CornerRadius="{TemplateBinding CornerRadius}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </ripple:RippleEffect>
                    </Panel>
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^:pointerover /template/ Border#PART_RootBorder">
            <Setter Property="assists:ShadowAssist.ShadowDepth" Value="Depth5" />
        </Style>
        <!-- <Style Selector="^:pointerover /template/ Border#PART_HoverEffect"> -->
        <!--     <Setter Property="Opacity" Value="0.12" /> -->
        <!-- </Style> -->

        <Style Selector="^:pressed /template/ Border#PART_RootBorder">
            <Setter Property="assists:ShadowAssist.ShadowDepth" Value="Depth2" />
        </Style>
    </Style>

    
</Styles>