<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:assists="using:CTUScheduler.Presentation.Shared.Styles.Assists">

    <Design.PreviewWith>
        <Border Padding="20"
                Height="100" Width="150">
                <Border Classes="ShadowCard" Background="Transparent"></Border>           
        </Border>
    </Design.PreviewWith>
    
    <Style Selector="Border.ShadowCard">
        <Setter Property="assists:ShadowAssist.ShadowDepth" Value="Depth1"/>
        <Style Selector="^:pointerover">
            <Setter Property="assists:ShadowAssist.ShadowDepth" Value="Depth3"/>
        </Style>
    </Style>
</Styles>