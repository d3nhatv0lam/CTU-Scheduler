<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ripple="clr-namespace:CTUScheduler.Presentation.Shared.Styles.Ripple">
    
    <ControlTheme x:Key="{x:Type ripple:RippleEffect}"
                  TargetType="ripple:RippleEffect"
                  BasedOn="{StaticResource {x:Type ContentControl}}">
        <Style Selector="^:not(.no-transitions)">
            <Setter Property="UseTransitions" Value="True"/>
        </Style>
    </ControlTheme>
</ResourceDictionary>
