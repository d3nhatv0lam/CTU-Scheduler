<rxui:ReactiveUserControl x:TypeArguments="timeline:TimelineViewModel"
                          xmlns="https://github.com/avaloniaui"
                          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                          mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="500"
                          xmlns:rxui="http://reactiveui.net"
                          xmlns:vm="clr-namespace:CTUScheduler.Presentation.Shared.Controls.Timeline"
                          xmlns:converters="clr-namespace:Avalonia.Controls.Converters;assembly=Avalonia.Controls"
                          xmlns:timeline="clr-namespace:CTUScheduler.Presentation.Shared.Controls.Timeline"
                          x:CompileBindings="True"
                          x:DataType="timeline:TimelineViewModel"
                          x:Class="CTUScheduler.Presentation.Shared.Controls.Timeline.TimelineControl">

    <Design.DataContext>
        <timeline:TimelineViewModel />
    </Design.DataContext>

    <rxui:ReactiveUserControl.Resources>
        <converters:EnumToBoolConverter x:Key="BuiltInEnumToBool"></converters:EnumToBoolConverter>
    </rxui:ReactiveUserControl.Resources>

    <Border CornerRadius="16"
            Padding="20">

        <StackPanel Spacing="18">
            <ItemsControl ItemsSource="{Binding Nodes}">
                <ItemsControl.ItemTemplate>

                    <DataTemplate x:DataType="timeline:TimelineNodeViewModel">

                        <Grid ColumnDefinitions="24,*"
                              Margin="0,0,0,14">

                            <!-- Timeline rail -->
                            <Grid>
                                <Border Width="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch"
                                        Background="#303030" />

                                <Ellipse Width="14"
                                         Height="14"
                                         Classes.upcoming="{Binding State, Converter={StaticResource BuiltInEnumToBool}, ConverterParameter=Upcoming}"
                                         Classes.active="{Binding State, Converter={StaticResource BuiltInEnumToBool}, ConverterParameter=Active}"
                                         Classes="active"
                                         VerticalAlignment="Top">
                                    
                                    <Ellipse.Transitions>
                                        <Transitions>
                                            <BrushTransition Property="Fill" Duration="0:0:0.3" />
                                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3"/>
                                        </Transitions>
                                    </Ellipse.Transitions>

                                    <Ellipse.Styles>
                                        <!-- Style mặc định (Completed) -->
                                        <Style Selector="Ellipse">
                                            <Setter Property="Fill" Value="#6B7280" />
                                            <Setter Property="RenderTransform">
                                                <ScaleTransform ScaleX="1" ScaleY="1" />
                                            </Setter>
                                        </Style>
                                        
                                        <!-- Upcoming State -->
                                        <Style Selector="Ellipse.upcoming">
                                            <Setter Property="Fill" Value="#9CA3AF" />
                                            <Setter Property="ScaleTransform.ScaleX" Value="0.85" />
                                            <Setter Property="ScaleTransform.ScaleY" Value="0.85" />
                                            <Setter Property="Opacity" Value="0.6"/>
                                        </Style>

                                        <!-- Active State -->
                                        <Style Selector="Ellipse.active">
                                            <Setter Property="Fill" Value="Green" />
                                            <Setter Property="Opacity" Value="1"/>
                                            <Style.Animations>
                                                <!-- Animation lặp lại vô hạn, kéo dài 2 giây -->
                                                <Animation Duration="0:0:2" IterationCount="Infinite" PlaybackDirection="Alternate">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="ScaleTransform.ScaleX" Value="1"/>
                                                        <Setter Property="ScaleTransform.ScaleY" Value="1"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="ScaleTransform.ScaleX" Value="1.3"/>
                                                        <Setter Property="ScaleTransform.ScaleY" Value="1.3"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Ellipse.Styles>
                                </Ellipse>
                            </Grid>

                            <!-- Content -->
                            <StackPanel Grid.Column="1"
                                        Spacing="4">

                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold" />

                                <TextBlock Text="{Binding DateRange}"
                                           Opacity="0.65"
                                           FontSize="12" />

                            </StackPanel>

                        </Grid>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>

    </Border>

</rxui:ReactiveUserControl>