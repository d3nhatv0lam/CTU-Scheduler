<rxui:ReactiveUserControl x:TypeArguments="timeline:TimelineViewModel"
                          xmlns="https://github.com/avaloniaui"
                          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                          mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
                          xmlns:rxui="http://reactiveui.net"
                          xmlns:vm="clr-namespace:CTUScheduler.Presentation.Shared.Controls.Timeline"
                          xmlns:converters="clr-namespace:Avalonia.Controls.Converters;assembly=Avalonia.Controls"
                          xmlns:timeline="clr-namespace:CTUScheduler.Presentation.Shared.Controls.Timeline"
                          x:CompileBindings="True"
                          x:DataType="timeline:TimelineViewModel"
                          x:Class="CTUScheduler.Presentation.Shared.Controls.Timeline.TimelineControl">

    <Design.DataContext>
        <timeline:TimelineViewModel />
    </Design.DataContext>

    <rxui:ReactiveUserControl.Resources>
        <converters:EnumToBoolConverter x:Key="BuiltInEnumToBool"></converters:EnumToBoolConverter>
    </rxui:ReactiveUserControl.Resources>

    <Border CornerRadius="16" ClipToBounds="False" Padding="8,4">
        <Grid>
            <ItemsControl ItemsSource="{Binding Nodes}"
                          ClipToBounds="False"
                          HorizontalAlignment="Stretch">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TimelineNodeViewModel">
                        <Grid ColumnDefinitions="24,*" Margin="0,0,0,10" MinHeight="64">
                            <!-- Timeline rail -->
                            <Grid>
                                <Border Width="2"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch"
                                        Background="#303030" />

                                <Ellipse Width="14"
                                         Height="14"
                                         Fill="{Binding ProgressBrush, Mode=OneWay}"
                                         VerticalAlignment="Top">

                                    <Ellipse.Transitions>
                                        <Transitions>
                                            <BrushTransition Property="Fill" Duration="0:0:0.3" />
                                        </Transitions>
                                    </Ellipse.Transitions>
                                </Ellipse>

                                <!-- Lớp hiệu ứng "Tỏa Sáng" đặt bên dưới Ellipse -->
                                <Border Width="20"
                                        Height="20"
                                        CornerRadius="14"
                                        Background="Transparent"
                                        VerticalAlignment="Top"
                                        BoxShadow="{Binding GlowStart}"
                                        IsVisible="{Binding State, Converter={StaticResource BuiltInEnumToBool}, ConverterParameter={x:Static vm:TimelineState.Active}}"
                                        IsHitTestVisible="False">
                                    <Border.Styles>
                                        <Style Selector="Border">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1.5"
                                                           IterationCount="INFINITE">
                                                    <KeyFrame Cue="0%">
                                                        <Setter Property="ScaleTransform.ScaleX" Value="0.8" />
                                                        <Setter Property="ScaleTransform.ScaleY" Value="0.8" />
                                                        <Setter Property="BoxShadow" Value="{Binding GlowStart}" />
                                                    </KeyFrame>
                                                    <KeyFrame Cue="100%">
                                                        <Setter Property="ScaleTransform.ScaleX" Value="1.5" />
                                                        <Setter Property="ScaleTransform.ScaleY" Value="1.5" />
                                                        <Setter Property="BoxShadow"
                                                                Value="{Binding GlowEnd}" />
                                                    </KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </Border.Styles>
                                </Border>
                            </Grid>

                            <!-- Content -->
                            <StackPanel Grid.Column="1"
                                        Spacing="12"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding DateRange}"
                                           Opacity="0.65"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>

</rxui:ReactiveUserControl>