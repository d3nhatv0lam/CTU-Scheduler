<rxui:ReactiveUserControl x:TypeArguments="timeline:TimelineViewModel"
                          xmlns="https://github.com/avaloniaui"
                          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                          mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="450"
                          xmlns:rxui="http://reactiveui.net"
                          xmlns:vm="clr-namespace:CTUScheduler.Presentation.Shared.Controls.Timeline"
                          xmlns:converters="clr-namespace:Avalonia.Controls.Converters;assembly=Avalonia.Controls"
                          xmlns:timeline="clr-namespace:CTUScheduler.Presentation.Shared.Controls.Timeline"
                          x:CompileBindings="True"
                          x:DataType="timeline:TimelineViewModel"
                          x:Class="CTUScheduler.Presentation.Shared.Controls.Timeline.TimelineControl">

    <Design.DataContext>
        <timeline:TimelineViewModel />
    </Design.DataContext>

    <rxui:ReactiveUserControl.Resources>
        <converters:EnumToBoolConverter x:Key="BuiltInEnumToBool"></converters:EnumToBoolConverter>
    </rxui:ReactiveUserControl.Resources>

    <rxui:ReactiveUserControl.Styles>
        <!-- Card Border Styles for State Classes -->
        <Style Selector="Border.upcoming">
            <Setter Property="Background" Value="#FFFFFF" /> <!-- Clean white -->
            <Setter Property="BorderBrush" Value="#F1F5F9" /> <!-- Slate-100 (clean & soft outline) -->
        </Style>
        <Style Selector="Border.completed">
            <Setter Property="Background" Value="#F8FAFC" /> <!-- Slate-50 -->
            <Setter Property="BorderBrush" Value="#E2E8F0" /> <!-- Slate-200 -->
            <Setter Property="BoxShadow" Value="0 2 6 0 #080F172A" /> <!-- Subtle elevation shadow for completed -->
        </Style>
        <Style Selector="Border.active" x:DataType="vm:TimelineNodeViewModel">
            <Setter Property="Background" Value="{Binding CardBackground, Mode=OneWay}" />
            <Setter Property="BorderBrush" Value="{Binding CardBorderBrush, Mode=OneWay}" />
            <Setter Property="BoxShadow" Value="{Binding CardBoxShadow, Mode=OneWay}" />
        </Style>

        <!-- TextBlock styles for Title -->
        <Style Selector="TextBlock.title">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Border.active TextBlock.title">
            <Setter Property="Foreground" Value="#1E1B4B" /> <!-- Indigo-950 (extremely sharp & premium) -->
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style Selector="Border.completed TextBlock.title">
            <Setter Property="Foreground" Value="#334155" /> <!-- Slate-700 -->
        </Style>
        <Style Selector="Border.upcoming TextBlock.title">
            <Setter Property="Foreground" Value="#94A3B8" /> <!-- Slate-400 (slightly dimmed) -->
        </Style>

        <!-- TextBlock styles for Date -->
        <Style Selector="Border.active TextBlock.date">
            <Setter Property="Foreground" Value="#4F46E5" /> <!-- Indigo-600 accent -->
        </Style>
        <Style Selector="Border.completed TextBlock.date">
            <Setter Property="Foreground" Value="#64748B" /> <!-- Slate-500 -->
        </Style>
        <Style Selector="Border.upcoming TextBlock.date">
            <Setter Property="Foreground" Value="#CBD5E1" /> <!-- Slate-300 -->
        </Style>
    </rxui:ReactiveUserControl.Styles>

    <Border CornerRadius="16" ClipToBounds="False" Padding="4,4">
        <ItemsControl ItemsSource="{Binding Nodes}"
                      ClipToBounds="False"
                      HorizontalAlignment="Stretch">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:TimelineNodeViewModel">
                    <Grid ColumnDefinitions="24,*" Margin="0,0,0,12" MinHeight="68">
                        <!-- Timeline rail -->
                        <Grid>
                            <Border Width="2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch"
                                    Background="#E2E8F0" />

                            <!-- Lớp hiệu ứng "Tỏa Sáng" đặt dưới Ellipse -->
                            <Border Width="16"
                                    Height="16"
                                    CornerRadius="12"
                                    Background="Transparent"
                                    VerticalAlignment="Top"
                                    Margin="0,11,0,0"
                                    BoxShadow="{Binding GlowStart}"
                                    IsVisible="{Binding State, Converter={StaticResource BuiltInEnumToBool}, ConverterParameter={x:Static vm:TimelineState.Active}}"
                                    IsHitTestVisible="False">
                                <Border.Styles>
                                    <Style Selector="Border">
                                        <Style.Animations>
                                            <Animation Duration="0:0:1.8"
                                                       IterationCount="INFINITE">
                                                <KeyFrame Cue="0%">
                                                    <Setter Property="ScaleTransform.ScaleX" Value="0.8" />
                                                    <Setter Property="ScaleTransform.ScaleY" Value="0.8" />
                                                    <Setter Property="BoxShadow" Value="{Binding GlowStart}" />
                                                </KeyFrame>
                                                <KeyFrame Cue="100%">
                                                    <Setter Property="ScaleTransform.ScaleX" Value="1.8" />
                                                    <Setter Property="ScaleTransform.ScaleY" Value="1.8" />
                                                    <Setter Property="BoxShadow" Value="{Binding GlowEnd}" />
                                                </KeyFrame>
                                            </Animation>
                                        </Style.Animations>
                                    </Style>
                                </Border.Styles>
                            </Border>

                            <Ellipse Width="10"
                                     Height="10"
                                     Fill="{Binding ProgressBrush, Mode=OneWay}"
                                     VerticalAlignment="Top"
                                     Margin="0,14,0,0">
                                <Ellipse.Transitions>
                                    <Transitions>
                                        <BrushTransition Property="Fill" Duration="0:0:0.3" />
                                    </Transitions>
                                </Ellipse.Transitions>
                            </Ellipse>
                        </Grid>

                        <!-- Content Card -->
                        <Border Grid.Column="1"
                                Classes.active="{Binding State, Converter={StaticResource BuiltInEnumToBool}, ConverterParameter={x:Static vm:TimelineState.Active}}"
                                Classes.completed="{Binding State, Converter={StaticResource BuiltInEnumToBool}, ConverterParameter={x:Static vm:TimelineState.Completed}}"
                                Classes.upcoming="{Binding State, Converter={StaticResource BuiltInEnumToBool}, ConverterParameter={x:Static vm:TimelineState.Upcoming}}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14,12"
                                Margin="4,0,0,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Title}"
                                           Classes="title"
                                           FontSize="13.5"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding DateRange}"
                                           Classes="date"
                                           FontSize="11.5"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Subtitle}"
                                           Foreground="#0284C7"
                                           Opacity="0.95"
                                           FontSize="11.5"
                                           FontWeight="Medium"
                                           LineHeight="17"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding Subtitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>

</rxui:ReactiveUserControl>