<rxui:ReactiveUserControl 
             x:TypeArguments="vm:ConfirmDialogViewModel" 
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             xmlns:rxui="http://reactiveui.net"
             x:DataType="vm:ConfirmDialogViewModel"
             x:CompileBindings="True"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:vm="clr-namespace:CTUScheduler.Presentation.Shared.Dialogs.ViewModels"
             x:Class="CTUScheduler.Presentation.Shared.Dialogs.Views.ConfirmDialogView">

    <rxui:ReactiveUserControl.Styles>
        <Style Selector="Border.DialogCard">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="MinWidth" Value="420"/>
            <Setter Property="MaxWidth" Value="480"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="BoxShadow" Value="0 8 32 0 #22000000"/>
        </Style>

        <Style Selector="Border.IconCircle">
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="CornerRadius" Value="28"/>
            <Setter Property="Background" Value="#DBEAFE"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.IconCircle.destructive">
            <Setter Property="Background" Value="#FEE2E2"/>
        </Style>

        <Style Selector="TextBlock.IconText">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.IconText.destructive">
            <Setter Property="Foreground" Value="{StaticResource RedColor}"/>
        </Style>

        <Style Selector="TextBlock.DialogTitle">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.DialogTitle.destructive">
            <Setter Property="Foreground" Value="{StaticResource RedColor}"/>
        </Style>

        <Style Selector="TextBlock.DialogMessage">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="MaxWidth" Value="340"/>
        </Style>

        <Style Selector="Border.DialogSeparator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{StaticResource BorderColor}"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style Selector="Button.BtnCancel">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.BtnCancel:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BaseBackgroundColor}"/>
        </Style>

        <Style Selector="Button.BtnConfirm">
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.BtnConfirm:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
        </Style>
        <Style Selector="Button.BtnConfirm.destructive">
            <Setter Property="Background" Value="{StaticResource RedColor}"/>
        </Style>
        <Style Selector="Button.BtnConfirm.destructive:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#B91C1C"/>
        </Style>

    </rxui:ReactiveUserControl.Styles>

    <Border Classes="DialogCard">
        <StackPanel>
            <StackPanel Spacing="10" Margin="28,20,28,16">
                <Border Classes="IconCircle"
                        Classes.destructive="{Binding IsDestructive}">
                    <TextBlock Classes="IconText"
                               Classes.destructive="{Binding IsDestructive}"
                               Text="?" />
                </Border>

                <TextBlock Classes="DialogTitle"
                           Classes.destructive="{Binding IsDestructive}"
                           Text="{Binding Title}" />

                <TextBlock Classes="DialogMessage"
                           Text="{Binding Message}" />
            </StackPanel>

            <Border Classes="DialogSeparator" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="12"
                        Margin="24,16,24,20">
                <Button Classes="BtnCancel"
                        Content="{Binding CancelText}"
                        Command="{Binding CancelCommand}" />
                <Button Classes="BtnConfirm"
                        Classes.destructive="{Binding IsDestructive}"
                        Content="{Binding ConfirmText}"
                        Command="{Binding AcceptCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</rxui:ReactiveUserControl>
