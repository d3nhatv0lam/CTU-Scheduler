<rxui:ReactiveUserControl 
             x:TypeArguments="vm:ConfirmDialogViewModel" 
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             xmlns:rxui="http://reactiveui.net"
             x:DataType="vm:ConfirmDialogViewModel"
             x:CompileBindings="True"
             Background="Transparent"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:vm="clr-namespace:CTUScheduler.Presentation.Shared.Dialogs.ViewModels"
             x:Class="CTUScheduler.Presentation.Shared.Dialogs.Views.ConfirmDialogView">

    <rxui:ReactiveUserControl.Styles>
        <Style Selector="Border.DialogCard">
            <Setter Property="Background" Value="{DynamicResource SemiColorBackground3}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="MinWidth" Value="440"/>
            <Setter Property="MaxWidth" Value="480"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="BoxShadow" Value="0 8 32 0 #1A000000"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="Border.IconBox">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style Selector="Border.IconBoxBg">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Opacity" Value="0.12"/>
        </Style>

        <Style Selector="materialIcons|MaterialIcon.Icon">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.DialogTitle">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style Selector="TextBlock.DialogMessage">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource SemiColorText1}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style Selector="Border.DialogSeparator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style Selector="Button.BtnCancel">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SemiColorText1}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.BtnCancel:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SemiColorFill1}"/>
        </Style>

        <Style Selector="Button.BtnConfirm">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.BtnConfirm:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>

        <Style Selector="Border.DialogCard.Warning Border.IconBoxBg">
            <Setter Property="Background" Value="{DynamicResource RedColor}"/>
        </Style>

        <Style Selector="Border.DialogCard.Warning Border.IconBox materialIcons|MaterialIcon">
            <Setter Property="Foreground" Value="{DynamicResource RedColor}"/>
        </Style>

        <Style Selector="Border.DialogCard.Warning TextBlock.DialogTitle">
            <Setter Property="Foreground" Value="{DynamicResource RedColor}"/>
        </Style>

        <Style Selector="Border.DialogCard.Warning Button.BtnConfirm">
            <Setter Property="Background" Value="{DynamicResource RedColor}"/>
        </Style>

        <Style Selector="Border.DialogCard.Warning Button.BtnConfirm:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource LightRedColor}"/>
            <Setter Property="TextElement.Foreground" Value="White"/>
        </Style>
    </rxui:ReactiveUserControl.Styles>

    <Border Classes="DialogCard" Classes.Warning="{Binding IsDestructive}">
        <StackPanel>
            <Grid ColumnDefinitions="Auto, *" Margin="24,24,24,20">
                <Border Grid.Column="0" 
                        Classes="IconBox"
                        Margin="0,0,16,0">
                    <Panel>
                        <!-- Nền mờ phía sau sử dụng Opacity cục bộ -->
                        <Border Classes="IconBoxBg" />
                        
                        <Grid>
                            <materialIcons:MaterialIcon Kind="HelpCircleOutline" 
                                                        Classes="Icon"
                                                        IsVisible="{Binding !IsDestructive}"/>
                            <materialIcons:MaterialIcon Kind="AlertOutline" 
                                                        Classes="Icon"
                                                        IsVisible="{Binding IsDestructive}"/>
                        </Grid>
                    </Panel>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <TextBlock Classes="DialogTitle"
                               Text="{Binding Title}" />
                    <TextBlock Classes="DialogMessage"
                               Text="{Binding Message}" />
                </StackPanel>
            </Grid>

            <Border Classes="DialogSeparator" />

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="12"
                        Margin="24,12,24,16">
                <Button Classes="BtnCancel"
                        Content="{Binding CancelText}"
                        Command="{Binding CancelCommand}" />
                <Button Classes="BtnConfirm"
                        Content="{Binding ConfirmText}"
                        Command="{Binding AcceptCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</rxui:ReactiveUserControl>
