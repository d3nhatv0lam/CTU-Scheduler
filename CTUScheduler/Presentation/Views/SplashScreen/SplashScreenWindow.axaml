<rxui:ReactiveWindow 
		x:TypeArguments="vm:SplashScreenViewModel" 
		xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="400"
		Height="400"
		Width="300"
		TransparencyLevelHint="Transparent"
		Background="Transparent"
		WindowStartupLocation="CenterScreen"
        x:Class="CTUScheduler.Presentation.Views.SplashScreen.SplashScreenWindow"
		ExtendClientAreaToDecorationsHint="True"
		ExtendClientAreaTitleBarHeightHint="0"
		CanResize="False"
		xmlns:rxui="http://reactiveui.net" 
		xmlns:vm="clr-namespace:CTUScheduler.Presentation.ViewModels.SplashScreen"
		x:DataType="vm:SplashScreenViewModel"
		x:CompileBindings="True"
		xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        Title="Splash Screen">
	
    <Border Background="{StaticResource PrimaryColor}" CornerRadius="10">
		<Grid RowDefinitions="auto * *">
			<Grid.Styles>
				<Style Selector="Button#CloseAppButton:pointerover">
						<Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
							<Setter Property="Background" Value="Transparent"/>
							<Setter Property="Foreground" Value="LightGray"/>
					</Style>
				</Style>
			</Grid.Styles>
			<Button Grid.Row="0" 
				 Name="CloseAppButton"
				 VerticalAlignment="Top" 
				 HorizontalAlignment="Right"
				 Background="Transparent"
				 Margin="0 10 10 0"
				 Height="30" 
				 Width="30"
				 Cursor="Hand"
				 Foreground="White" 
				 Content="{materialIcons:MaterialIconExt Kind=CloseThick,Size=30}" 
				/>
			<Image Grid.Row="1" Height="180" Source="avares://CTUScheduler/Assets/Images/CTU Logo/CTU_logo_180x180.png"/>
			 <Grid Grid.Row="2" RowDefinitions="10 auto auto 15 auto 5 * auto 5">
				 <Grid.Styles>
					 <Style Selector="TextBlock">
						 <Setter Property="HorizontalAlignment" Value="Center"/>
						 <Setter Property="VerticalAlignment" Value="Center"/>
						 <Setter Property="Foreground" Value="White"/>
						 <Setter Property="FontFamily" Value="{StaticResource CTU_Title_Font}"/>
					 </Style>
					<Style Selector="TextBlock.Title">
						<Setter Property="FontFamily" Value="{StaticResource CTU_Text_Font}"/>
					</Style>
				 </Grid.Styles>
				 
				 
				 <TextBlock Grid.Row="1"
							Classes="Title"
							FontSize="20"
							Text="CTU Scheduler"
							/>
				
				<Separator Grid.Row="2" Background="White"/>

					
				<ProgressBar Grid.Row="4" IsIndeterminate="True" Width="200" Height="15" Foreground="White"/>
				<Panel Grid.Row="6">
					<TextBlock Name="MessageTextBlock"
							   VerticalAlignment="Center" 
							   HorizontalAlignment="Center"
							   TextWrapping="Wrap"
							   TextAlignment="Center"/>
				</Panel>
				<TextBlock Grid.Row="7" 
						   x:Name="AppVersionTextBlock" 
						   VerticalAlignment="Center" 
						   HorizontalAlignment="Center"/>
			 </Grid>
		</Grid>
		
	</Border>
</rxui:ReactiveWindow>
