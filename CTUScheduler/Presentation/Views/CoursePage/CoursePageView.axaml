<rxui:ReactiveUserControl
			x:TypeArguments="vm:CoursePageViewModel"
			xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:rxui="http://reactiveui.net"
			 xmlns:vm="clr-namespace:CTUScheduler.Presentation.ViewModels.CoursePage"
			 xmlns:components="clr-namespace:CTUScheduler.Presentation.ViewModels.CoursePage.Components"
			 x:DataType="vm:CoursePageViewModel"
			 x:CompileBindings="True"
             x:Class="CTUScheduler.Presentation.Views.CoursePage.CoursePageView">

	<Design.DataContext>
		<vm:CoursePageViewModel/>
	</Design.DataContext>

	<Grid>
		<TextBlock Text="CoursePage" FontSize="100"/>
	</Grid>
</rxui:ReactiveUserControl>
