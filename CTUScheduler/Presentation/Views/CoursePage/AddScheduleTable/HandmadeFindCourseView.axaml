
<rxui:ReactiveUserControl
			 x:TypeArguments="vm:HandmadeFindCourseViewModel"
			 xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="500"
			  xmlns:rxui="http://reactiveui.net"
			 xmlns:vm="clr-namespace:CTUScheduler.Presentation.ViewModels.CoursePage.AddScheduleTable"
			 xmlns:qSelectCourse ="clr-namespace:CTUScheduler.Core.Models.Academic.Curriculum.CourseData.Raw;assembly=CTUScheduler"
			 xmlns:selectableCourseData="using:CTUScheduler.Presentation.ViewModels.CoursePage.AddScheduleTable.Components"
			 xmlns:courseData="using:CTUScheduler.Core.Models.Academic.Curriculum.CourseData.Processed"
			 x:DataType="vm:HandmadeFindCourseViewModel"
			 x:CompileBindings="True"
			 xmlns:p1="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
			 xmlns:controls="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
			 xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="CTUScheduler.Presentation.Views.CoursePage.AddScheduleTable.HandmadeFindCourseView">

	<rxui:ReactiveUserControl.Styles>

		<Style Selector="TextBlock">
			<Setter Property="FontFamily" Value="{StaticResource Text_Font}"/>
		</Style>
		
		<Style Selector="Border.CornerBorder">
			<Setter Property="BorderBrush" Value="#a3a3a3"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Background" Value="White"/>
			<Setter Property="CornerRadius" Value="10"/>
		</Style>
		<Style Selector="TextBlock.Title">
			<Setter Property="FontSize" Value="20"/>
			<Setter Property="FontWeight" Value="Bold"/>
		</Style>
	</rxui:ReactiveUserControl.Styles>
	
	<Grid ColumnDefinitions="* 0.025* 0.5*">
		<!--// left side //-->
		<Border Grid.Column="0" Padding="0 3 0 3">
			<Border Classes="CornerBorder">
				<Grid RowDefinitions="auto 1 auto *" ClipToBounds="True">
					<!--// title //-->
					<TextBlock
							 Grid.Row="0"
							 x:Name="txtCourseInfo"
							 Classes="Title"
							 MaxHeight="70"
							 Text="Danh mục học phần"
							 HorizontalAlignment="Left"
							 Margin="10 0 0 0"
							 TextWrapping="WrapWithOverflow"
						>
					</TextBlock>

					<Border Grid.Row="1" Height="1"  Padding="10 0 10 0">
						<Separator Grid.Row="1" Margin="0"  Background="#a3a3a3"/>
					</Border>

					<!--// Search bar //-->
					<Border Grid.Row="2" Padding="10 0 10 0">
						<DockPanel
								   LastChildFill="False" 
								   ClipToBounds="True">
							<!--// search field //-->
							<TextBox
								x:Name="tboxCourseKeyInput"
								Width="165"
								DockPanel.Dock="Left"
								UseFloatingWatermark="True"
								Text="{Binding TxtInputCourseKey ,Mode=TwoWay}"
								Classes="outline"
								Theme="{StaticResource OutlineTextBox}"
								p1:TextFieldAssist.Label="Mã học phần"
								>
								<TextBox.IsFocused>
									<Binding Path="IsTxtInputCourseKeyFocused" Mode="OneWayToSource" />
								</TextBox.IsFocused>
							</TextBox>
							<!--// search button //-->
							<Button
								 x:Name="btnSearchCourse"
								 CornerRadius="40"
								 Content="{materialIcons:MaterialIconExt Kind=Search,Size=30}"
								 Width="40"
								 Height="40"
								 Margin="5 5 0 0"
								 VerticalAlignment="Center"
								 Padding="0"					 
								 DockPanel.Dock="Left"
								 Command="{Binding SearchCommand}"
								 />
							
							<CheckBox DockPanel.Dock="Left" 
									  Margin="10 5 0 0" 
									  VerticalAlignment="Center" 
									  Padding="0"
									  Content="Ẩn nhóm đủ sĩ số"
									  />
							<!--// add button //-->
							<Button DockPanel.Dock="Right"
									Height="30"
									Padding="5"
									Margin="0 5 0 0"
									CornerRadius="5"
									>
								<StackPanel Orientation="Horizontal">
									<materialIcons:MaterialIcon Kind="PlusCircleOutline"  Height="20" Width="20"/>
									<TextBlock VerticalAlignment="Center" Text="Thêm học phần" Margin="2 0 0 0"/>
								</StackPanel>
							</Button>
						</DockPanel>
					</Border>

					<!--// Quick select popup //-->
					<Popup 
						  PlacementTarget="{Binding ElementName=tboxCourseKeyInput}" 
						   Placement="BottomEdgeAlignedLeft"
						   IsOpen="{Binding IsQuickSelectPopupOpened,Mode=OneWay}"
							MaxHeight="200" Width="210"
						  >
						
						<controls:Card
								CornerRadius="5"
								Background="White"
								BorderThickness="1"
								BorderBrush="#a3a3a3"
								Padding="1"
								ClipToBounds="True">

							<ListBox x:Name="lboxQuickSelect"
									 SelectedItem="{Binding SelectedQuickSelectCourse,Mode=TwoWay}"
									 ItemsSource="{Binding QuickSelectCourses,Mode=OneWay}"
									 >
									
								<ListBox.ItemsPanel>
									<ItemsPanelTemplate>
										<StackPanel/>
									</ItemsPanelTemplate>
								</ListBox.ItemsPanel>

								<ListBox.ItemTemplate>
									<DataTemplate x:DataType ="{x:Type qSelectCourse:QuickSelectCourse}">
										<Grid Background="Transparent">
											<TextBlock Text="{Binding Information,Mode= OneTime}"/>
											<ToolTip.Tip>
												<TextBlock Text="{Binding Information,Mode= OneTime}"/>
											</ToolTip.Tip>
										</Grid>
									</DataTemplate>
								</ListBox.ItemTemplate>
								
							</ListBox>
						</controls:Card>
					</Popup>
					
					
					<!--// DataGrid //-->
					<Border Grid.Row="3"  Padding="8">
						<ScrollViewer HorizontalScrollBarVisibility="Disabled"
									  VerticalScrollBarVisibility="Auto">
							<DataGrid
							  ClipToBounds="True"
							  BorderBrush="#a3a3a3"
							  ClipboardCopyMode="IncludeHeader"
							  CanUserReorderColumns="False"
							  CanUserSortColumns="False"
							  CanUserResizeColumns="True"
							  IsReadOnly="False"
							  ColumnHeaderHeight="40"
							  SelectionMode="Single"
							  ItemsSource="{Binding CoursesCatalog,Mode=OneWay}"
							  AutoGenerateColumns="False">
							<DataGrid.Styles>
								<Style Selector="TextBlock">
									<Setter Property="HorizontalAlignment" Value="Center"/>
									<Setter Property="VerticalAlignment" Value="Center"/>
									<Setter Property="Background" Value="Transparent"/>
									<Setter Property="TextWrapping" Value="WrapWithOverflow"/>
								</Style>
								
								<!--<Style Selector="DataGridRow:nth-child(even)">
									<Setter Property="Background" Value="#f0f0f0"/>
								</Style>-->
							</DataGrid.Styles>
							
							<DataGrid.Columns>
								<DataGridTemplateColumn Header="Chọn" Width="69" CanUserResize="False">
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate x:DataType="{x:Type selectableCourseData:SelectableCourseData}">
											<CheckBox
												VerticalAlignment="Center"
												HorizontalAlignment="Center"
												IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
								</DataGridTemplateColumn>
								<DataGridTextColumn Binding="{Binding Item.Group, Mode=OneWay}" 
													IsReadOnly="True" 
													Header="Nhóm" 
													MinWidth="60"/>
								<DataGridTextColumn Binding="{Binding Item.TotalStudents, Mode=OneWay}" 
													IsReadOnly="True"
													Header="Sĩ số" 
													MinWidth="50" 
													Width="auto"/>
								<DataGridTextColumn Binding="{Binding Item.RemainingStudents, Mode=OneWay}" 
													IsReadOnly="True" 
													Header="Sĩ số còn lại" 
													MinWidth="80" 
													Width="80"/>
								<DataGridTemplateColumn Header="Lịch học">
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate x:DataType="{x:Type selectableCourseData:SelectableCourseData}">
											<ItemsRepeater
												ItemsSource="{Binding Item.ClassDayDatas,Mode=OneTime}"
												 	>
												
												<ItemsRepeater.ItemTemplate>
													<DataTemplate DataType="{x:Type courseData:ClassDayData}">
														<Grid ColumnDefinitions="0.3* * 0.3*">
															<TextBlock  Grid.Column="0"
																Text="{Binding AttendingDay,Mode=OneTime}"
															/>
															<TextBlock
																Grid.Column="1"
																Text="{Binding Period}"
																/>
															<TextBlock Grid.Column="2"
																	Text="{Binding Room,Mode=OneTime}"
																	   />
														</Grid>
													</DataTemplate>
												</ItemsRepeater.ItemTemplate>
											
											</ItemsRepeater>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
								</DataGridTemplateColumn>
								<DataGridTemplateColumn 
									Header="Giảng viên" 
									Width="*">
									<DataGridTemplateColumn.CellTemplate>
										<DataTemplate x:DataType="{x:Type selectableCourseData:SelectableCourseData}">
											<Grid>
												<TextBlock Text="{Binding Item.Lecturer, Mode=OneWay}"/>
											</Grid>
										</DataTemplate>
									</DataGridTemplateColumn.CellTemplate>
								</DataGridTemplateColumn>
							</DataGrid.Columns>

						</DataGrid>
				
						</ScrollViewer>
						</Border>
				</Grid>
			</Border>
		</Border>
		<!--// right side //-->
		<Border Grid.Column="2" Padding="0 3 0 3">
			<Border Classes="CornerBorder">
				<Grid RowDefinitions="auto 1 *" >
					<TextBlock
							 Grid.Row="0"
							 Classes="Title"
							 Text="Học phần đã chọn"
							 HorizontalAlignment="Left"
							 Margin="10 0 0 0"
										/>

					<Border Grid.Row="1" Height="1"  Padding="10 0 10 0">
						<Separator Grid.Row="1" Margin="0"  Background="#a3a3a3"/>
					</Border>

					<!--// TreeView //-->
					<Border Grid.Row="2"  Padding="8">
						
					</Border>
				</Grid>
			</Border>
		</Border>
	</Grid>
</rxui:ReactiveUserControl>

