<rxui:ReactiveUserControl
	        x:TypeArguments="vm:AddCourseShellViewModel"
	        xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             xmlns:rxui="http://reactiveui.net"
			 xmlns:vm="clr-namespace:CTUScheduler.Presentation.ViewModels.CoursePage.AddScheduleTable"
			 x:DataType="vm:AddCourseShellViewModel"
			 x:CompileBindings="True"
			 xmlns:controls="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
			 xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="CTUScheduler.Presentation.Views.CoursePage.AddScheduleTable.AddCourseShellView">

	<Design.DataContext>
		<vm:AddCourseShellViewModel/>
	</Design.DataContext>

	<controls:Card
		 Height="500"
		 Padding="0"
		 Width="800">
		
		<Button Height="200" Width="200" Content="quay ve" Command="{Binding NavigateBackCommand}"/>
		
	</controls:Card>


</rxui:ReactiveUserControl>
